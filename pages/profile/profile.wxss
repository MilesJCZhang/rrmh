/* pages/profile/profile.wxss */

.page {
  min-height: 100vh;
  background: var(--bg-warm);
  padding-bottom: 60rpx;
}

.mt-24 { margin-top: 24rpx; }

/* ========== 头像区域 ========== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 72rpx 0 32rpx;
}

/* 头像外框：红色渐变圆环 */
.avatar-wrap {
  position: relative;
  width: 216rpx;
  height: 216rpx;
  border-radius: 50%;
  padding: 8rpx;
  background: linear-gradient(135deg, var(--red-primary), var(--red-dark));
  box-shadow: 0 6rpx 24rpx rgba(200, 16, 46, 0.25);
  box-sizing: border-box;
}

/* 圆形头像本体 */
.avatar-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  background-color: var(--bg-white);
  overflow: hidden;
}

/* 无头像时的占位 */
.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--red-pale);
}

.avatar-icon {
  font-size: 60rpx;
  opacity: 0.6;
}

/* 透明触发按钮：覆盖整个头像 */
.avatar-trigger {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: transparent;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  opacity: 0;
}
.avatar-trigger::after {
  border: none !important;
  border-radius: 50% !important;
}

/* 相机角标 */
.avatar-badge {
  position: absolute;
  right: 4rpx;
  bottom: 4rpx;
  width: 52rpx;
  height: 52rpx;
  background: var(--red-primary);
  border-radius: 50%;
  border: 4rpx solid var(--bg-white);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  z-index: 2;
  pointer-events: none;
}

.avatar-badge-icon {
  font-size: 24rpx;
}

.avatar-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

/* ========== 表单区域 ========== */
.text-right {
  text-align: right;
}

.placeholder {
  color: var(--text-light) !important;
  text-align: right;
}

/* ========== 性别选择器 ========== */
.gender-group {
  display: flex;
  gap: 16rpx;
}
.gender-item {
  padding: 6rpx 24rpx;
  border-radius: 100rpx;
  border: 2rpx solid #E0E0E0;
  font-size: 26rpx;
  color: #666;
  background: #FAFAFA;
  line-height: 1.8;
}
.gender-item:active { opacity: 0.7; }
.gender-active {
  border-color: #C8102E;
  color: #C8102E;
  background: #FFF0F0;
}

/* ========== 昵称输入区域 ========== */
.form-row .form-input {
  text-align: right;
  padding-right: 0;
}

/* ========== 自我介绍卡片 ========== */
.intro-card {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  margin: 24rpx 32rpx 0;
  padding: 28rpx 32rpx 32rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid rgba(200, 16, 46, 0.05);
}

.intro-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.intro-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.intro-count {
  font-size: 22rpx;
  color: var(--text-light);
}

.intro-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  background: var(--bg-warm);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
}

/* ========== 保存按钮 ========== */
.save-btn {
  margin: 48rpx 48rpx 0;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: var(--radius-full);
  background: linear-gradient(135deg, var(--red-primary), var(--red-dark));
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: var(--shadow-btn);
  border: none;
  text-align: center;
}

.save-btn::after {
  border: none;
}

.save-btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

.save-btn[disabled] {
  opacity: 0.6;
}

.safe-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
}
