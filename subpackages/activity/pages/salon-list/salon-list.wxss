/* subpackages/activity/pages/salon-list/salon-list.wxss */

.page {
  min-height: 100vh;
  background: var(--bg-page, #FDF6F0);
  padding-bottom: 120rpx;
  padding-top: calc(var(--status-bar-height, 88rpx) + 60rpx + 8rpx);
}

/* ---- 固定导航栏（不随页面滚动，主题色背景，最上层） ---- */
.salon-fixed-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  padding-top: var(--status-bar-height, 88rpx);
  padding-left: 24rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.15);
  pointer-events: none;
}
.salon-nav-back {
  pointer-events: auto;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
}
.salon-nav-back:active {
  background: rgba(255,255,255,0.35);
}
.salon-nav-arrow {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* ---- 页面头部 ---- */
.page-header {
  background: linear-gradient(135deg, #C8102E, #E8454A);
  padding: 24rpx 32rpx 40rpx;
  color: #FFFFFF;
  position: relative;
  overflow: hidden;
}
.page-header::before {
  content: '❃';
  position: absolute;
  right: -20rpx;
  top: -30rpx;
  font-size: 180rpx;
  color: rgba(255,255,255,0.05);
  pointer-events: none;
}
.page-header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  font-family: STKaiti, KaiTi, serif;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
}
.page-header-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
  line-height: 1.6;
  margin-bottom: 24rpx;
}
.header-badges {
  display: flex;
  gap: 16rpx;
}
.badge-item {
  flex: 1;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.badge-num {
  font-size: 28rpx;
  font-weight: 800;
}
.badge-label {
  font-size: 20rpx;
  opacity: 0.75;
}

/* ---- 男/女推荐官主题差异化 ---- */
.male-theme .page-header {
  background: linear-gradient(135deg, #1565C0, #42A5F5) !important;
}
.female-theme .page-header {
  background: linear-gradient(135deg, #C2185B, #F06292) !important;
}

/* ---- Tier等级提示 ---- */
.tier-tip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 32rpx;
  background: #FFF8E8;
  border-bottom: 1rpx solid #FFE082;
}
.tier-tip-icon { font-size: 28rpx; flex-shrink: 0; }
.tier-tip-text { font-size: 24rpx; color: #795548; }

/* ---- Tier筛选Tab ---- */
.tier-tab-bar {
  display: flex;
  background: #FFFFFF;
  padding: 16rpx 32rpx;
  gap: 12rpx;
  border-bottom: 1rpx solid #F0E8E0;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tier-tab {
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #999;
  background: #F5F5F5;
  border: 1rpx solid #E8E8E8;
  transition: all 0.15s;
}
.tier-tab.tier-tab-active {
  background: var(--red-pale, #FDF0F0);
  color: #C8102E;
  font-weight: 700;
  border-color: #C8102E;
}

/* ---- 沙龙卡片列表 ---- */
.salon-cards {
  padding: 20rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.salon-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  border: 1rpx solid rgba(200,16,46,0.06);
  position: relative;
  overflow: hidden;
}
.salon-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 5rpx; height: 100%;
  background: linear-gradient(180deg, #C8102E, #D4A017);
}
.salon-card:active { transform: scale(0.99); opacity: 0.9; }

.sc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.sc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  font-family: STKaiti, KaiTi, serif;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sc-tier-badge {
  font-size: 20rpx;
  font-weight: 600;
  color: #D4A017;
  background: #FFF8E8;
  border: 1rpx solid #F0D080;
  border-radius: 100rpx;
  padding: 4rpx 16rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.sc-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}
.sc-date { font-weight: 600; color: #666; }
.sc-time { color: #888; }
.sc-location { color: #888; }

/* 3男3女分组名额条 */
.sc-group-bar {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #F0F0F0;
}
.sc-gender-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 6rpx 0;
}
.sc-gender-row + .sc-gender-row {
  margin-top: 8rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #F0F0F0;
}
.sc-gender-label { font-size: 28rpx; width: 40rpx; flex-shrink: 0; }
.sc-slot-dots {
  display: flex;
  gap: 10rpx;
  flex: 1;
}
.sc-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #F0F0F0;
  border: 2rpx dashed #DDD;
}
.sc-dot.filled {
  background: var(--red-pale, #FDF0F0);
  border: 2rpx solid #C8102E;
  border-style: solid;
}
.sc-dot.filled-f {
  background: #FCE4EC;
  border: 2rpx solid #C2185B;
  border-style: solid;
}
.sc-gender-remain {
  font-size: 22rpx;
  color: #999;
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}
.sc-cap-tip {
  font-size: 20rpx;
  color: #aaa;
  text-align: center;
  margin-top: 6rpx;
}

/* 底部价格+操作 */
.sc-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12rpx;
  border-top: 1rpx solid #F5F0F0;
}
.sc-price {
  display: flex;
  align-items: baseline;
}
.sc-price-sym {
  font-size: 26rpx;
  font-weight: 700;
  color: #C8102E;
}
.sc-price-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #C8102E;
  line-height: 1;
}
.sc-price-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}
.sc-cta {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #C8102E, #E8454A);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 16rpx rgba(200,16,46,0.3);
}
.sc-cta:active { opacity: 0.85; transform: scale(0.96); }
.sc-cta.sc-cta-disabled {
  background: #E0E0E0;
  color: #999;
  box-shadow: none;
}
.sc-cta.sc-cta-done {
  background: #52C41A;
  color: #FFFFFF;
  box-shadow: none;
}

/* ---- 加载/空状态 ---- */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}
.loading-text {
  font-size: 28rpx;
  color: #999;
}
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}
.empty-icon-text {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.empty-hint {
  font-size: 30rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 8rpx;
}
.empty-sub {
  font-size: 24rpx;
  color: #999;
}

/* ---- 推荐官浮动按钮 ---- */
.fab-create {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #C8102E, #E8454A);
  border-radius: 56rpx;
  box-shadow: 0 8rpx 32rpx rgba(200,16,46,0.4);
  z-index: 10;
}
.fab-create:active { transform: scale(0.95); }
.fab-create-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: 700;
  line-height: 1;
}
.fab-create-text {
  font-size: 18rpx;
  color: #FFFFFF;
  font-weight: 500;
  margin-top: 4rpx;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
