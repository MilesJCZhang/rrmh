/* ---- 输入推荐码入口 ---- */
.input-code-row {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-sm);
