/* pages/reunion/reunion-profile.wxss */
.page { min-height: 100vh; background: var(--bg-page); padding-bottom: 160rpx; }
.mx-32 { margin-left: 32rpx; margin-right: 32rpx; }

.step-header { padding: 32rpx 0 24rpx; }
.step-h-title { font-size: 36rpx; font-weight: 800; color: var(--text-primary); margin-bottom: 8rpx; }
.step-h-desc { font-size: 26rpx; color: var(--text-secondary); }

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f8f8f8;
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}
.radio-group { display: flex; gap: 20rpx; }
.radio-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-secondary);
  background: #f8f8f8;
}
.radio-item.checked { border-color: #7649A4; background: #F5EEFF; color: #7649A4; font-weight: 700; }

.voice-section {
  margin-top: 24rpx;
  padding: 28rpx;
  background: var(--bg-page);
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(118,73,164,0.12);
}
.voice-header { margin-bottom: 16rpx; }
.voice-title { font-size: 28rpx; font-weight: 700; color: var(--text-primary); }
.voice-sub { font-size: 24rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }
.voice-btn {
  height: 88rpx;
  background: linear-gradient(135deg, #7649A4, #4A2870);
  color: #fff;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(118,73,164,0.4);
}
.voice-btn.recording { transform: scale(1.05); box-shadow: 0 8rpx 32rpx rgba(118,73,164,0.6); }
.voice-status { font-size: 24rpx; color: #27ae60; display: block; margin-top: 12rpx; }

.footer-btns {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10px);
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.06);
}

/* 付款 */
.pay-confirm-page { padding-top: 60rpx; padding-bottom: 40rpx; text-align: center; }
.pay-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.pay-title { font-size: 40rpx; font-weight: 800; margin-bottom: 16rpx; }
.pay-amount { font-size: 32rpx; color: var(--text-secondary); margin-bottom: 32rpx; }
.pay-num { font-size: 80rpx; font-weight: 900; color: #7649A4; }

.pay-info-card {
  background: #F5EEFF;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  text-align: left;
  border: 1rpx solid #D8B4FE;
}
.pay-info-item { display: flex; margin-bottom: 16rpx; }
.pay-info-item:last-child { margin-bottom: 0; }
.pii-label { font-size: 24rpx; color: #7649A4; font-weight: 700; width: 160rpx; flex-shrink: 0; }
.pii-val { font-size: 24rpx; color: var(--text-secondary); flex: 1; }

.pay-desc-list { text-align: left; margin-bottom: 8rpx; }
.pay-desc-item { font-size: 26rpx; color: var(--text-secondary); padding: 6rpx 0; }

/* 等待 */
.waiting-page { padding-top: 80rpx; text-align: center; }
.waiting-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.waiting-title { font-size: 44rpx; font-weight: 800; color: var(--text-primary); margin-bottom: 12rpx; }
.waiting-desc { font-size: 28rpx; color: var(--text-secondary); line-height: 1.7; margin-bottom: 40rpx; }

.share-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 36rpx;
  box-shadow: var(--shadow);
  text-align: left;
}
.share-title { font-size: 32rpx; font-weight: 800; margin-bottom: 12rpx; }
.share-desc { font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; }

.avatar-preview-card {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.avatar-preview-icon { font-size: 52rpx; }
.avatar-preview-name { font-size: 28rpx; font-weight: 700; margin-bottom: 4rpx; }
.avatar-preview-status { font-size: 22rpx; color: var(--text-secondary); }
