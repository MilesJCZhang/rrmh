<!--pages/matchmaker/apply/apply.wxml - 公益推荐官申请页面-->
<view class="container">
  <view class="header">
    <text class="title">申请公益推荐官</text>
    <text class="subtitle">成为公益推荐官，帮助他人找到幸福</text>
  </view>

  <view class="form-card">
    <view class="form-item">
      <text class="label">姓名</text>
      <input class="input" placeholder="请输入真实姓名" value="{{form.real_name}}" bindinput="onInput" data-field="real_name" />
    </view>

    <view class="form-item">
      <text class="label">性别</text>
      <radio-group class="radio-group" bindchange="onGenderChange">
        <label class="radio-label">
          <radio value="male" checked="{{form.gender === 'male'}}" />男
        </label>
        <label class="radio-label">
          <radio value="female" checked="{{form.gender === 'female'}}" />女
        </label>
      </radio-group>
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" />
    </view>

    <view class="form-item">
      <text class="label">微信号</text>
      <input class="input" placeholder="请输入微信号" value="{{form.wechat}}" bindinput="onInput" data-field="wechat" />
    </view>

    <view class="form-item">
      <text class="label">推荐人ID（选填）</text>
      <input class="input" type="number" placeholder="请输入推荐人用户ID" value="{{form.referrer_id}}" bindinput="onInput" data-field="referrer_id" />
    </view>
  </view>

  <button class="submit-btn" bindtap="onSubmit">提交申请</button>

  <view class="tips">
    <text class="tips-text">提交后，我们将在1-3个工作日内审核您的申请。审核通过后，您将获得公益推荐官身份。</text>
  </view>
</view>