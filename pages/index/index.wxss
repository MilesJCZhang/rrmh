/* ============================================================
   pages/index/index.wxss
   人人媒好首页 · 5分类大卡片 + 3功能宫格
   ============================================================ */

/* ---- 磨砂玻璃导航栏 ---- */
.glass-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
}
.glass-nav-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(200, 16, 46, 0.45);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}
.glass-nav-inner {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  height: 44px;
  padding: 0 28rpx;
}
.nav-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.35);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.2);
}
.nav-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  font-family: STKaiti, KaiTi, serif;
  margin-left: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}
.nav-placeholder {
  width: 80rpx;
}

/* ---- 顶部广告轮播 Banner ---- */
.hero-banner {
  position: relative;
  height: 420rpx;
  overflow: hidden;
}
.hero-swiper {
  width: 100%;
  height: 100%;
}
.hero-slide {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* 后台上传的轮播背景图 */
.hero-slide-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none; /* 穿透触摸到 swiper-item 的 bindtap 处理跳转 */
}

/* --- 主题：男推荐官沙龙深海蓝 --- */
.hero-slide--blue {
  background: linear-gradient(135deg, #0D47A1 0%, #1976D2 40%, #42A5F5 100%);
}
.hero-slide--blue .hs-deco-1 {
  width: 260rpx; height: 260rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.07);
  top: -60rpx; right: -40rpx;
}
.hero-slide--blue .hs-deco-2 {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  bottom: -20rpx; left: -30rpx;
}
.hero-slide--blue .hs-deco-3 {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  top: 40%; left: 60rpx;
}
.hero-slide--blue .hs-cta {
  background: rgba(255, 255, 255, 0.18);
}
.hero-slide--blue .hs-hl-dot {
  background: #90CAF9;
}

/* --- 主题：女推荐官沙龙玫瑰金 --- */
.hero-slide--pink {
  background: linear-gradient(135deg, #880E4F 0%, #C2185B 40%, #F06292 100%);
}
.hero-slide--pink .hs-deco-1 {
  width: 260rpx; height: 260rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.07);
  top: -60rpx; left: -40rpx;
}
.hero-slide--pink .hs-deco-2 {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  bottom: -20rpx; right: -30rpx;
}
.hero-slide--pink .hs-deco-3 {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  top: 40%; right: 60rpx;
}
.hero-slide--pink .hs-cta {
  background: rgba(255, 255, 255, 0.18);
}
.hero-slide--pink .hs-hl-dot {
  background: #F48FB1;
}

/* --- 主题：AI科技蓝 --- */
.hero-slide--tech {
  background: linear-gradient(135deg, #0F2B5B 0%, #1A4FA0 40%, #2B6CB0 100%);
}
.hero-slide--tech .hs-deco-1 {
  width: 300rpx; height: 300rpx; border-radius: 50%;
  background: rgba(59, 130, 246, 0.15);
  top: -80rpx; right: -60rpx;
}
.hero-slide--tech .hs-deco-2 {
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: rgba(59, 130, 246, 0.1);
  bottom: -40rpx; left: -40rpx;
}
.hero-slide--tech .hs-deco-3 {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: rgba(96, 165, 250, 0.12);
  top: 50%; left: 30rpx;
}
.hero-slide--tech .hs-cta {
  background: rgba(59, 130, 246, 0.3);
}
.hero-slide--tech .hs-hl-dot {
  background: #60A5FA;
}

/* --- 主题：推荐官中国红 --- */
.hero-slide--red {
  background: linear-gradient(135deg, #6B0F1A 0%, #C8102E 40%, #E8454A 100%);
}
.hero-slide--red .hs-deco-1 {
  width: 280rpx; height: 280rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  top: -60rpx; left: -60rpx;
}
.hero-slide--red .hs-deco-2 {
  width: 180rpx; height: 180rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  bottom: 20rpx; right: -30rpx;
}
.hero-slide--red .hs-deco-3 {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
  top: 30%; right: 60rpx;
}
.hero-slide--red .hs-cta {
  background: rgba(255, 255, 255, 0.15);
}
.hero-slide--red .hs-hl-dot {
  background: #FCA5A5;
}

/* --- 主题：线下活动暖橙 --- */
.hero-slide--love {
  background: linear-gradient(135deg, #B45309 0%, #D97706 40%, #F59E0B 100%);
}
.hero-slide--love .hs-deco-1 {
  width: 250rpx; height: 250rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  top: -50rpx; right: 40rpx;
}
.hero-slide--love .hs-deco-2 {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  bottom: -30rpx; left: -20rpx;
}
.hero-slide--love .hs-deco-3 {
  width: 90rpx; height: 90rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.09);
  top: 40%; left: 80rpx;
}
.hero-slide--love .hs-cta {
  background: rgba(255, 255, 255, 0.2);
}
.hero-slide--love .hs-hl-dot {
  background: #FDE68A;
}

/* 装饰圆 */
.hs-deco {
  position: absolute;
  pointer-events: none;
}

/* 背景大图案 */
.hs-pattern {
  position: absolute;
  right: 40rpx;
  bottom: 80rpx;
  font-size: 160rpx;
  opacity: 0.08;
  transform: rotate(-15deg);
  pointer-events: none;
}

/* 内容层：左右布局 */
.hero-slide .hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 32rpx;
  width: 100%;
  box-sizing: border-box;
  height: 100%;
  padding-bottom: 80rpx;
}
.hero-banner .hero-title {
  font-size: 46rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  font-family: STKaiti, KaiTi, serif;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
  margin-bottom: 6rpx;
}
.hero-banner .hero-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

/* 功能亮点 */
.hs-highlights {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
}
.hs-hl-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.hs-hl-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.6);
  flex-shrink: 0;
}
.hs-hl-text {
  font-size: 20rpx;
  color: rgba(255,255,255,0.85);
  letter-spacing: 1rpx;
}

/* CTA 按钮 */
.hs-cta {
  position: absolute;
  right: 32rpx;
  bottom: 40rpx;
  z-index: 3;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10rpx);
  border-radius: 100rpx;
  padding: 12rpx 28rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
}
.hs-cta-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}
.hs-cta-arrow {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  font-weight: 700;
}
.hero-slide:active .hs-cta {
  background: rgba(255,255,255,0.25);
}

/* ---- 推荐推荐官展示条 ---- */
.referrer-bar {
  margin: 16rpx 0 12rpx;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFF1F2, #FFFFFF);
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  border: 1rpx solid rgba(200, 16, 46, 0.08);
  box-shadow: 0 2rpx 12rpx rgba(200, 16, 46, 0.06);
}
.ref-avatar-box {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C8102E, #E8393E);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(200, 16, 46, 0.2);
}
.ref-avatar-text {
  font-size: 30rpx;
  font-weight: 900;
  color: #FFFFFF;
  font-family: STKaiti, KaiTi, serif;
}
.ref-body {
  flex: 1;
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
}
.ref-label {
  font-size: 20rpx;
  color: var(--text-muted);
}
.ref-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-top: 2rpx;
}
.ref-right {
  flex-shrink: 0;
}
.ref-link {
  font-size: 22rpx;
  color: #C8102E;
  font-weight: 500;
}

/* ---- 推荐码状态提示条 ---- */
.guide-tip {
  margin: 12rpx 32rpx 8rpx;
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  background: #FFF7ED;
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(200,16,46,0.08);
  border: 1rpx solid rgba(200,16,46,0.06);
}
.guide-tip:active { opacity: 0.85; }

/* 已获取推荐码状态（绿色风格） */
.guide-tip--has-code {
  background: #F0FFF4;
  border-color: rgba(72, 187, 120, 0.25);
  box-shadow: 0 4rpx 16rpx rgba(72, 187, 120, 0.10);
}

.guide-tip-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C8102E, #E8393E);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.guide-tip-icon--success {
  background: linear-gradient(135deg, #48BB78, #68D391);
}
.gti-text {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 800;
}
.guide-tip-body { flex: 1; }
.guide-tip-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}
.guide-tip-code {
  font-size: 28rpx;
  font-weight: 800;
  color: #48BB78;
  display: block;
  margin-top: 4rpx;
  letter-spacing: 2rpx;
}
.guide-tip-desc {
  font-size: 20rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 2rpx;
}
.guide-tip-arrow {
  font-size: 20rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #C8102E, #E8393E);
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  flex-shrink: 0;
  font-weight: 500;
}
.guide-tip--has-code .guide-tip-arrow {
  background: linear-gradient(135deg, #48BB78, #68D391);
}

/* ============================================================
   分类滑动入口 — Swiper 大卡片
   ============================================================ */
.cat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.cat-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.cat-title-deco {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, var(--red-primary), var(--red-dark));
}
.cat-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-primary);
  font-family: STKaiti, KaiTi, serif;
}
.cat-dots {
  display: flex;
  gap: 10rpx;
}
.cat-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #E0D6D0;
  transition: all 0.3s;
}
.cat-dot.active {
  width: 28rpx;
  border-radius: 6rpx;
  background: var(--red-primary);
}

.cat-swiper {
  height: 360rpx;
  border-radius: var(--radius-xl);
}

/* -- Mini 轮播（缩小版） -- */
.cat-swiper--mini {
  height: 180rpx;
}
.cat-card--mini {
  border-radius: var(--radius-lg);
}
.cat-card-inner--mini {
  padding: 24rpx 28rpx;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.cat-mini-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  flex: 1;
}
.cat-name--mini {
  font-size: 32rpx;
  font-weight: 800;
  color: #FFFFFF;
  font-family: STKaiti, KaiTi, serif;
  letter-spacing: 2rpx;
  margin-bottom: 4rpx;
}
.cat-age--mini {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 10rpx;
}
.cat-mini-stat {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.cat-stat-num--mini {
  font-size: 30rpx;
  font-weight: 800;
  color: #FFFFFF;
}
.cat-stat-label--mini {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
}
.cat-mini-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}
.cat-arrow-wrap--mini {
  background: rgba(255,255,255,0.22);
  border-radius: 100rpx;
  padding: 8rpx 22rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
}
.cat-referral-hint--mini {
  position: static;
  background: rgba(0,0,0,0.35);
  backdrop-filter: blur(6rpx);
  border-radius: 100rpx;
  padding: 6rpx 14rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
}

/* -- 分类卡片基础 -- */
.cat-card {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-xl);
  position: relative;
  overflow: hidden;
  margin: 0 4rpx;
}
.cat-card:active { transform: scale(0.98); }

/* 装饰圆 */
.cat-card-deco {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}
.cat-card-deco-1 {
  width: 280rpx;
  height: 280rpx;
  right: -60rpx;
  top: -80rpx;
  background: rgba(255,255,255,0.08);
}
.cat-card-deco-2 {
  width: 180rpx;
  height: 180rpx;
  left: -40rpx;
  bottom: -40rpx;
  background: rgba(255,255,255,0.06);
}
.cat-card-deco-3 {
  width: 120rpx;
  height: 120rpx;
  right: 80rpx;
  bottom: 20rpx;
  background: rgba(255,255,255,0.04);
}

.cat-card-inner {
  position: relative;
  z-index: 2;
  padding: 32rpx 36rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* -- 各主题渐变背景 -- */
.cat-card--young {
  background: linear-gradient(135deg, #C8102E 0%, #E8393E 40%, #FF6B6B 100%);
}
.cat-card--middle {
  background: linear-gradient(135deg, #7649A4 0%, #9B59B6 50%, #C39BD3 100%);
}
.cat-card--senior {
  background: linear-gradient(135deg, #D4A017 0%, #E8B828 50%, #F0D060 100%);
}
.cat-card--divorced {
  background: linear-gradient(135deg, #1E8449 0%, #27AE60 50%, #52BE80 100%);
}
.cat-card--reunion {
  background: linear-gradient(135deg, #6C3483 0%, #9B59B6 40%, #D2B4DE 100%);
}

/* 标签行 */
.cat-tags {
  display: flex;
  gap: 10rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}
.cat-tag {
  font-size: 20rpx;
  color: rgba(255,255,255,0.92);
  background: rgba(255,255,255,0.18);
  border-radius: 100rpx;
  padding: 4rpx 18rpx;
  border: 1rpx solid rgba(255,255,255,0.22);
  backdrop-filter: blur(4rpx);
}

/* 人群名称 */
.cat-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  font-family: STKaiti, KaiTi, serif;
  letter-spacing: 4rpx;
  margin-bottom: 6rpx;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.15);
}

/* 年龄范围 */
.cat-age {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

/* 描述 */
.cat-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  line-height: 1.5;
}

/* 底部信息行 */
.cat-footer {
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.cat-stat {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}
.cat-stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
}
.cat-stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}
.cat-arrow-wrap {
  background: rgba(255,255,255,0.2);
  border-radius: 100rpx;
  padding: 12rpx 28rpx;
  border: 1rpx solid rgba(255,255,255,0.25);
}
.cat-arrow {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 右上角主题 emoji */
.cat-emoji {
  position: absolute;
  right: 32rpx;
  top: 24rpx;
  font-size: 64rpx;
  z-index: 3;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.15));
}

/* 无推荐人时卡片右上角小提示 */
.cat-referral-hint {
  position: absolute;
  top: 20rpx;
  left: 24rpx;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(0,0,0,0.45);
  backdrop-filter: blur(8rpx);
  border-radius: 100rpx;
  padding: 8rpx 18rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
}
.cat-referral-hint:active { opacity: 0.8; }
.crh-icon { font-size: 22rpx; }
.crh-text {
  font-size: 20rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 500;
}

/* ============================================================
   八宫格入口（4列 × 2行 = 8格）
   ============================================================ */
/* ---- 二宫格：社交建档 + 成为推荐官 ---- */
.grid2-wrap {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.grid2-card {
  position: relative;
  border-radius: var(--radius-xl);
  padding: 32rpx 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 260rpx;
  box-shadow: var(--shadow-md);
}
.grid2-card:active {
  opacity: 0.88;
}

/* 社交建档 - 品牌红渐变 */
.grid2-card--dating {
  background: linear-gradient(155deg, #C8102E 0%, #E8393E 50%, #FF6B6B 100%);
  color: #fff;
}
/* 成为推荐官 - 金色渐变 */
.grid2-card--matchmaker {
  background: linear-gradient(155deg, #B8860B 0%, #D4A017 50%, #F0C75E 100%);
  color: #fff;
}
/* 男推荐官主题沙龙 - 深蓝渐变 */
/* 女推荐官主题沙龙 - 玫红渐变 */

/* 装饰圆圈 */
.grid2-deco {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
  pointer-events: none;
}
.grid2-deco-1 {
  width: 160rpx; height: 160rpx;
  background: #fff;
  top: -40rpx; right: -30rpx;
}
.grid2-deco-2 {
  width: 100rpx; height: 100rpx;
  background: #fff;
