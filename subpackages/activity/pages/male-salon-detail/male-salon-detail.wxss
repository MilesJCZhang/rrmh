/* subpackages/activity/pages/male-salon-detail/male-salon-detail.wxss */
/* 男推荐官沙龙详情页样式 - 蓝色商务风 */

.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 160rpx;
}

/* ---- 封面 ---- */
.cover-wrap {
  position: relative;
  width: 100%;
  height: 400rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #1565C0, #42A5F5);
}

.cover-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 80% 20%, rgba(255,255,255,0.12) 0%, transparent 60%);
  pointer-events: none;
}

.cover-body {
  position: relative;
  z-index: 2;
  padding: 24rpx 32rpx;
  padding-top: calc(var(--status-bar-h, 20px) + 8rpx);
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.cover-badge {
  display: inline-block;
  background: rgba(255,255,255,0.25);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  margin-bottom: 16rpx;
  align-self: flex-start;
}

.cover-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.3;
  margin-bottom: 6rpx;
}

.cover-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

/* ---- 核心规格卡片 ---- */
.spec-card {
  margin: -24rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 2;
}

.spec-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.spec-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.spec-num {
  font-size: 30rpx;
  font-weight: 800;
  color: #1565C0;
}

.spec-label {
  font-size: 20rpx;
  color: #999;
}

.spec-divider {
  width: 1rpx;
  height: 60rpx;
  background: #F0E8E0;
}

/* ---- 信息卡片 ---- */
.info-card {
  margin: 24rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.info-row + .info-row {
  border-top: 1rpx solid #F0E8E0;
}

.info-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.info-icon--date {
  background: #E3F2FD;
}

.info-icon--location {
  background: #E8F5E9;
}

.info-icon-char {
  font-size: 24rpx;
  font-weight: 700;
  color: #1565C0;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.info-label {
  font-size: 22rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* ---- 活动说明 ---- */
.desc-block {
  margin: 24rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  font-size: 28rpx;
  color: #333333;
  line-height: 1.9;
  white-space: pre-wrap;
}

/* ---- 底部操作栏 ---- */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.footer-inner {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.footer-price {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
}

.price-symbol {
  font-size: 26rpx;
  font-weight: 700;
  color: #1565C0;
}

.price-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #1565C0;
  line-height: 1;
}

.price-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

.price-free {
  font-size: 36rpx;
  font-weight: 800;
  color: #4CAF50;
  line-height: 1;
}

.btn {
  min-height: 88rpx;
  padding: 10rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1.4;
  border-radius: 44rpx;
  text-align: center;
  white-space: normal;
  word-break: break-all;
}

.btn-block {
  width: 100%;
}

.footer-btn {
  flex: 1;
}

.btn-primary {
  background: linear-gradient(135deg, #1565C0, #42A5F5);
  color: #FFFFFF;
}

.btn-cancel-reg {
  background: #FFFFFF;
  color: #1565C0;
  border: 2rpx solid #1565C0;
  font-weight: 600;
}

.footer-status-text {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

/* ---- 加载/空态 ---- */
.loading-wrap,
.empty-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text,
.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ---- 通用辅助 ---- */
.px-32 { padding-left: 32rpx; padding-right: 32rpx; }
.mt-24 { margin-top: 24rpx; }
.mb-160 { margin-bottom: 160rpx; }
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ---- 推荐官席位可视化 ---- */
.slot-section {
  padding: 24rpx 32rpx 0;
}

.group-visual-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(21,101,192,0.08);
  border: 1rpx solid rgba(21,101,192,0.1);
}

.gv-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 12rpx 0;
}

.gv-label {
  font-size: 28rpx;
  font-weight: 700;
  width: 160rpx;
  flex-shrink: 0;
  color: #1565C0;
}

.gv-slots {
  display: flex;
  gap: 16rpx;
  flex: 1;
  flex-wrap: wrap;
}

.gv-slot {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.gv-slot.filled {
  background: #E3F2FD;
  color: #1565C0;
  border: 2rpx solid #1565C0;
}

.gv-slot.empty {
  background: #FAFAFA;
  color: #DDD;
  border: 2rpx dashed #E0E0E0;
}

.gv-remain {
  font-size: 24rpx;
  color: #666;
  width: 120rpx;
  text-align: right;
  flex-shrink: 0;
}

.gv-cap-tip {
  font-size: 20rpx;
  color: #999;
  text-align: center;
  margin-top: 6rpx;
}

/* ---- 通用段落标题 ---- */
.section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 20rpx;
}

/* ---- 服务保障 ---- */
.highlight-grid {
  margin: 24rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.highlight-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.highlight-check {
  color: #1565C0;
  font-weight: 700;
  font-size: 26rpx;
  flex-shrink: 0;
}

.highlight-text {
  font-size: 26rpx;
  color: #333333;
}

/* ---- info-icon--host ---- */
.info-icon--host {
  background: #FFF8EE;
}

/* ---- 全局按钮重置 ---- */
button {
  border: none;
  outline: none;
  background: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

button::after {
  border: none;
}

/* ---- 我的报名 ---- */
.my-reg-section {
  padding: 24rpx 32rpx 0;
}

.my-reg-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.my-reg-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.my-reg-row + .my-reg-row {
  border-top: 1rpx solid #F5F0F0;
}

.my-reg-label {
  font-size: 26rpx;
  color: #999;
}

.my-reg-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* ---- 报名资料弹窗 ---- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 32rpx;
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 28rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.modal-actions .btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.modal-actions .btn-secondary {
  background: #F5F5F5;
  color: #666;
}

.modal-actions .btn-primary {
  background: linear-gradient(135deg, #1565C0, #42A5F5);
  color: #FFFFFF;
}

.modal-actions .btn-primary[loading] {
  opacity: 0.7;
}

/* ---- 表单 ---- */
.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 76rpx;
  background: #FAFAFA;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 100rpx;
  background: #FAFAFA;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  background: #FAFAFA;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

radio-group {
  display: flex;
  gap: 24rpx;
  padding: 12rpx 0;
}

radio-group label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #555;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-top: 24rpx;
  margin-bottom: 16rpx;
}

.btn-add-companion {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  color: #1565C0;
  font-size: 26rpx;
  font-weight: 600;
  width: 100%;
  background: transparent;
}
