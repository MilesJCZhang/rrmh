/* subpackages/activity/pages/female-salon-create/female-salon-create.wxss */
/* 女推荐官沙龙创建页样式 - 粉色商务风 */

.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 200rpx;
}

/* ---- 类型锁定 banner ---- */
.type-banner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 40rpx 32rpx;
  color: #FFFFFF;
  border-radius: 0 0 32rpx 32rpx;
}
.type-banner-icon {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; flex-shrink: 0;
  backdrop-filter: blur(4rpx);
}
.type-banner-info { display: flex; flex-direction: column; gap: 6rpx; }
.type-banner-title { font-size: 34rpx; font-weight: 700; }
.type-banner-desc { font-size: 22rpx; color: rgba(255,255,255,0.8); }

/* ---- 表单区域 ---- */
.form-section { padding: 24rpx 32rpx; }

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.form-group { margin-bottom: 28rpx; }
.form-group:last-child { margin-bottom: 0; }

.form-label {
  font-size: 28rpx; font-weight: 600; color: #333;
  margin-bottom: 12rpx; display: flex; align-items: center; gap: 6rpx;
}
.required { color: #C2185B; margin-left: 4rpx; }

.form-input {
  width: 100%; height: 88rpx;
  background: #FAFBFC; border: 2rpx solid #F0E8EC;
  border-radius: 14rpx; padding: 0 24rpx;
  font-size: 28rpx; color: #333;
  box-sizing: border-box; transition: border-color 0.2s;
}
.form-input:focus { border-color: #C2185B; background: #fff; }

.form-textarea {
  width: 100%; min-height: 200rpx;
  background: #FAFBFC; border: 2rpx solid #F0E8EC;
  border-radius: 14rpx; padding: 24rpx;
  font-size: 28rpx; color: #333;
  box-sizing: border-box; line-height: 1.6;
  transition: border-color 0.2s;
}

.form-hint {
  font-size: 22rpx; color: #999;
  margin-top: 8rpx; display: block;
  padding-left: 4rpx;
}

.section-title {
  font-size: 30rpx; font-weight: 600; color: #1a1a2e;
  margin-bottom: 24rpx; display: flex; align-items: center; gap: 8rpx;
  padding-bottom: 16rpx; border-bottom: 2rpx solid #f0f2f5;
}

/* ---- 日期时间选择 ---- */
.datetime-row { display: flex; gap: 16rpx; }
.datetime-picker {
  flex: 1; height: 88rpx;
  background: #FAFBFC; border: 2rpx solid #F0E8EC;
  border-radius: 14rpx; display: flex; align-items: center;
  padding: 0 24rpx; font-size: 28rpx; color: #333;
  box-sizing: border-box;
}
.datetime-picker::after { content: '›'; color: #ccc; font-size: 32rpx; margin-left: auto; }
.placeholder { color: #C0C0C0; }

/* ---- 封面上传 ---- */
.cover-upload {
  width: 100%; height: 320rpx;
  background: #FAFBFC; border-radius: 14rpx;
  border: 2rpx dashed #E8D5DC; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  transition: border-color 0.2s;
}
.cover-upload:active { border-color: #C2185B; }
.cover-preview { width: 100%; height: 100%; }
.cover-placeholder {
  display: flex; flex-direction: column; align-items: center; gap: 12rpx;
}
.cover-placeholder-icon { font-size: 64rpx; color: #C4BCC4; line-height: 1; }
.cover-placeholder-text { font-size: 24rpx; color: #999; }

/* ---- 提交区域 ---- */
.submit-wrap {
  padding: 16rpx 32rpx 32rpx;
  display: flex; flex-direction: column; align-items: center; gap: 16rpx;
}
.submit-btn {
  width: 100%; height: 96rpx;
  line-height: 96rpx; border-radius: 48rpx;
  font-size: 32rpx; font-weight: 700;
  color: #FFFFFF; text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(194,24,91,0.3);
  transition: transform 0.15s;
}
.submit-btn:active { transform: scale(0.97); }
.submit-btn[disabled] { opacity: 0.6; }
.submit-hint { font-size: 22rpx; color: #999; }

/* ---- 审核状态卡片 ---- */
.audit-status-card {
  margin: 0 32rpx 32rpx;
  background: #FFFFFF; border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(194,24,91,0.06);
  border: 1rpx solid rgba(194,24,91,0.1);
}
.audit-status-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.audit-status-icon { font-size: 32rpx; }
.audit-status-title { font-size: 28rpx; font-weight: 700; color: #333; }
.audit-status-desc { font-size: 24rpx; color: #666; line-height: 1.5; }
