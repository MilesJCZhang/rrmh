/* subpackages/activity/pages/salon-create/salon-create.wxss */
.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 200rpx;
}

/* ---- 类型锁定 banner ---- */
.type-banner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
  color: #FFFFFF;
}
.type-banner-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.type-banner-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.type-banner-title {
  font-size: 32rpx;
  font-weight: 700;
}
.type-banner-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

/* ---- 表单区域 ---- */
.form-section {
  padding: 24rpx 32rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #C8102E;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 1rpx solid #E8E0E0;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 1rpx solid #E8E0E0;
  line-height: 1.6;
}

.form-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* ---- 日期时间选择 ---- */
.datetime-row {
  display: flex;
  gap: 16rpx;
}

.datetime-picker {
  flex: 1;
  height: 88rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #E8E0E0;
  box-sizing: border-box;
}

.placeholder {
  color: #C0C0C0;
}

/* ---- 封面上传 ---- */
.cover-upload {
  width: 100%;
  height: 320rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 2rpx dashed #D0C8C8;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-preview {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.cover-placeholder-icon {
  font-size: 64rpx;
  color: #C0C0C0;
  line-height: 1;
}

.cover-placeholder-text {
  font-size: 24rpx;
  color: #999;
}

/* ---- 提交区域 ---- */
.submit-wrap {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-align: center;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.submit-hint {
  font-size: 22rpx;
  color: #999;
}
