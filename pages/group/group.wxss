/* pages/group/group.wxss */
.page { min-height: 100vh; background: var(--bg-page); padding-bottom: 40rpx; }
.mx-32 { margin-left: 32rpx; margin-right: 32rpx; }
.group-header { padding: 60rpx 40rpx; display: flex; flex-direction: column; align-items: center; }
.gh-emoji { font-size: 64rpx; margin-bottom: 12rpx; }
.gh-title { font-size: 40rpx; font-weight: 800; color: #fff; margin-bottom: 8rpx; }
.gh-meta { font-size: 24rpx; color: rgba(255,255,255,0.8); }
.rules-card {}
.rules-title { font-size: 30rpx; font-weight: 700; margin-bottom: 16rpx; }
.rules-list { display: flex; flex-direction: column; gap: 10rpx; }
.rule-item { font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; }
.members-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16rpx; }
.member-card { background: #fff; border-radius: var(--radius-md); padding: 20rpx; display: flex; flex-direction: column; align-items: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.mc-avatar { width: 80rpx; height: 80rpx; border-radius: 40rpx; margin-bottom: 8rpx; }
.mc-name { font-size: 22rpx; font-weight: 600; margin-bottom: 6rpx; text-align: center; }
.mc-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 4rpx; }
.chat-stream { display: flex; flex-direction: column; gap: 16rpx; }
.cs-item { display: flex; align-items: flex-start; gap: 12rpx; }
.cs-avatar { width: 64rpx; height: 64rpx; border-radius: 32rpx; flex-shrink: 0; }
.cs-bubble { flex: 1; background: #fff; border-radius: 16rpx; padding: 16rpx 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.cs-name { font-size: 22rpx; color: var(--primary); font-weight: 700; display: block; margin-bottom: 4rpx; }
.cs-msg { font-size: 26rpx; color: var(--text-primary); line-height: 1.5; }
.cs-aigc-tag { font-size: 18rpx; color: #9E9E9E; display: block; margin-top: 6rpx; }
.cs-time { font-size: 20rpx; color: var(--text-hint); flex-shrink: 0; margin-top: 8rpx; }
.aigc-banner { display: flex; align-items: center; gap: 10rpx; background: #FFF8E1; border: 1rpx solid #FFE082; border-radius: 12rpx; padding: 14rpx 20rpx; margin-bottom: 16rpx; }
.aigc-banner-icon { font-size: 28rpx; flex-shrink: 0; }
.aigc-banner-text { font-size: 22rpx; color: #795548; line-height: 1.5; }
.fi-title { font-size: 28rpx; font-weight: 700; margin-bottom: 4rpx; }
.fi-sub { font-size: 22rpx; color: var(--text-secondary); }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
