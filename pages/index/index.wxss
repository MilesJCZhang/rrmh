  margin-top: 20rpx;
}
.input-code-row:active { opacity: 0.85; }
.input-code-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #B8860B, #D4A017);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.input-code-icon-text {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
}
.input-code-info { flex: 1; }
.input-code-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}
.input-code-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 2rpx;
}

/* ---- 输入推荐码弹窗 ---- */
.modal-body {
  padding: 8rpx 0 24rpx;
}
.code-input-wrap {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  border: 2rpx solid #E8E8E8;
}
.code-input-wrap:focus-within {
  border-color: var(--red-primary);
  background: #FFFFFF;
}
.code-input {
  width: 100%;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 4rpx;
}
.code-input::placeholder {
  font-weight: 400;
  color: var(--text-light);
  letter-spacing: 2rpx;
}
.code-error {
  font-size: 24rpx;
  color: #E53935;
  margin-top: 12rpx;
  padding-left: 8rpx;
}

/* ---- 扫码绑定入口（保持原有样式） ---- */
.scan-row {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx dashed var(--red-light);
}
.scan-row:active { opacity: 0.85; }
.scan-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--red-primary), var(--red-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.scan-icon-text {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
}
.scan-info { flex: 1; }
.scan-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}
.scan-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 2rpx;
}
.scan-arrow {
  font-size: 28rpx;
  color: var(--text-light);
}

/* ---- 引导弹窗 ---- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}
.modal-box {
  width: 100%;
  max-width: 600rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 40rpx;
  position: relative;
}
.modal-header {
  text-align: center;
  margin-bottom: 36rpx;
}
.modal-icon-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--red-primary), var(--red-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(200,16,46,0.3);
}
.modal-icon-text {
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 800;
  font-family: STKaiti, KaiTi, serif;
}
.modal-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.modal-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.6;
}
.modal-steps { margin-bottom: 36rpx; }
.step-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
}
.step-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--red-primary), var(--red-dark));
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.step-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
}
.modal-actions { margin-bottom: 16rpx; }
.modal-close {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-muted);
  padding: 12rpx 0;
}

/* ---- 通用 ---- */
.link-text { font-size: 26rpx; color: var(--red-primary); font-weight: 500; }
