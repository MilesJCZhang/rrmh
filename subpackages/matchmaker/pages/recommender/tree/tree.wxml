<!-- pages/recommender/tree/tree.wxml -->
<view class="page-container">
  <!-- 统计信息 -->
  <view class="stats-card" wx:if="{{stats}}">
    <view class="stat-item">
      <text class="stat-value">{{stats.total_members}}</text>
      <text class="stat-label">团队总人数</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">¥{{stats.total_commission}}</text>
      <text class="stat-label">团队总收益</text>
    </view>
  </view>

  <!-- 树状图展示 -->
  <view class="tree-container" wx:if="{{tree}}">
    <view class="tree-title">推荐关系树</view>
    <view class="tree-root">
      <view class="tree-node root-node">
        <view class="node-content">
          <text class="node-icon">👑</text>
          <view class="node-info">
            <text class="node-name">{{tree.name}}</text>
            <text class="node-role">{{tree.role}}</text>
          </view>
          <text class="node-code" wx:if="{{tree.code}}">{{tree.code}}</text>
        </view>
      </view>

      <!-- 递归展示子节点 -->
      <view class="tree-children" wx:if="{{tree.children}}">
        <block wx:for="{{tree.children}}" wx:key="id">
          <view class="tree-node child-node">
            <view class="node-content">
              <text class="node-icon">👤</text>
              <view class="node-info">
                <text class="node-name">{{item.name}}</text>
                <text class="node-role">{{item.role}}</text>
              </view>
              <text class="node-code" wx:if="{{item.code}}">{{item.code}}</text>
            </view>
          </view>

          <!-- 二级节点 -->
          <view class="tree-children level-2" wx:if="{{item.children}}">
            <block wx:for="{{item.children}}" wx:for-item="child" wx:key="id">
              <view class="tree-node grandchild-node">
                <view class="node-content">
                  <text class="node-icon">👥</text>
                  <view class="node-info">
                    <text class="node-name">{{child.name}}</text>
                    <text class="node-role">{{child.role}}</text>
                  </view>
                  <text class="node-code" wx:if="{{child.code}}">{{child.code}}</text>
                </view>
              </view>
            </block>
          </view>
        </block>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-box" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-box" wx:if="{{!tree && !loading}}">
    <text class="empty-icon">🌳</text>
    <text class="empty-text">暂无推荐关系</text>
    <text class="empty-sub">分享您的推荐码，建立推荐网络</text>
  </view>

  <!-- 导出按钮 -->
  <view class="export-bar" wx:if="{{tree}}">
    <button class="btn-export" bindtap="exportPDF">
      📄 导出PDF报告
    </button>
  </view>
</view>
