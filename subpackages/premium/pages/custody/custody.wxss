/* subpackages/premium/pages/custody/custody.wxss */
.page { min-height: 100vh; background: var(--bg-page); padding: 32rpx; padding-bottom: 40rpx; }

.create-header { text-align: center; margin-bottom: 28rpx; }
.create-icon { font-size: 64rpx; display: block; margin-bottom: 8rpx; }
.create-title { font-size: 36rpx; font-weight: 800; color: var(--text-primary); font-family: STKaiti, KaiTi, serif; letter-spacing: 2rpx; }
.create-sub { font-size: 24rpx; color: var(--text-muted); margin-top: 6rpx; }

.create-card {
  background: #FFFFFF; border-radius: 16rpx; padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(160,120,32,0.12);
  border: 1rpx solid rgba(212,160,23,0.15);
  margin-bottom: 28rpx;
}
.cc-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 0; border-bottom: 1rpx solid #F5F0E0;
}
.cc-row:last-child { border-bottom: none; }
.cc-label { font-size: 26rpx; color: #999; }
.cc-value { font-size: 30rpx; font-weight: 700; color: #A07820; }
.cc-refund { color: #16a34a; }
.cc-years { display: flex; align-items: center; gap: 8rpx; }
.cc-years-input {
  width: 80rpx; height: 60rpx; text-align: center; font-size: 32rpx; font-weight: 700;
  background: #FFF8E8; border-radius: 8rpx; border: 2rpx solid #F0D080; color: #A07820;
}
.cc-years-unit { font-size: 24rpx; color: #999; }

/* 托管记录 */
.records-section { margin-top: 28rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 16rpx; font-family: STKaiti, KaiTi, serif; letter-spacing: 2rpx; }

.custody-card {
  background: #FFFFFF; border-radius: 16rpx; padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  border: 1rpx solid rgba(212,160,23,0.1);
  margin-bottom: 16rpx; position: relative; overflow: hidden;
}
.custody-card::before {
  content: ''; position: absolute; top: 0; left: 0;
  width: 5rpx; height: 100%;
  background: linear-gradient(180deg, #D4A017, #A07820);
}

.cust-status-badge {
  display: inline-block; font-size: 22rpx; font-weight: 600;
  padding: 4rpx 16rpx; border-radius: 100rpx; margin-bottom: 12rpx;
}
.cust-status-badge.pending { background: #FFF7ED; color: #C2410C; border: 1rpx solid #FED7AA; }
.cust-status-badge.active { background: #F0FDF4; color: #16a34a; border: 1rpx solid #BBF7D0; }
.cust-status-badge.settled { background: #EFF6FF; color: #2563EB; border: 1rpx solid #BFDBFE; }
.cust-status-badge.refunded { background: #F0FDF4; color: #16a34a; border: 1rpx solid #BBF7D0; }

.cust-amount { margin-bottom: 16rpx; }
.cust-amount-sym { font-size: 26rpx; font-weight: 700; color: #A07820; }
.cust-amount-num { font-size: 52rpx; font-weight: 900; color: #A07820; line-height: 1; }

.cust-details { }
.cust-row { display: flex; justify-content: space-between; padding: 8rpx 0; }
.cust-label { font-size: 24rpx; color: #999; }
.cust-val { font-size: 24rpx; color: #666; font-weight: 500; }

/* 保障说明 */
.guarantee-section { margin-top: 28rpx; }
.guarantee-item {
  display: flex; gap: 16rpx; padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F0E0;
}
.guarantee-item:last-child { border-bottom: none; }
.guarantee-icon { font-size: 36rpx; flex-shrink: 0; }
.guarantee-info { flex: 1; }
.guarantee-title { font-size: 28rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 4rpx; }
.guarantee-desc { font-size: 24rpx; color: #999; line-height: 1.5; }

/* 空状态 */
.empty-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 0; gap: 8rpx;
}
.empty-icon { font-size: 64rpx; margin-bottom: 8rpx; }
.empty-text { font-size: 28rpx; font-weight: 600; color: #666; }
.empty-sub { font-size: 24rpx; color: #999; text-align: center; }
