/* ============================================================
   pages/avatar/avatar.wxss
   AI分身页 · 暗色科技 + 国风红脉冲
   ============================================================ */

/* ---- 介绍横幅 ---- */
.intro-banner {
  padding: 72rpx 48rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.intro-banner::before {
  content: '❃';
  position: absolute;
  right: -20rpx; top: -20rpx;
  font-size: 280rpx;
  color: rgba(255,255,255,0.05);
  pointer-events: none;
}
.intro-icon {
  font-size: 88rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 8rpx 20rpx rgba(0,0,0,0.25));
}
.intro-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 14rpx;
  font-family: STKaiti, KaiTi, serif;
  letter-spacing: 3rpx;
}
/* 显著AI生成标识 - 介绍横幅 */
.ai-generate-badge {
  background: rgba(255, 255, 255, 0.95);
  color: #C8102E;
  font-size: 24rpx;
  font-weight: 700;
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #C8102E;
  letter-spacing: 2rpx;
}
.intro-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.82);
  line-height: 1.7;
  margin-bottom: 28rpx;
  max-width: 580rpx;
}
.intro-tags  { display: flex; gap: 16rpx; flex-wrap: wrap; justify-content: center; }
.intro-tag {
  background: rgba(255,255,255,0.18);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  border: 1rpx solid rgba(255,255,255,0.25);
}

/* ---- 功能说明卡片 ---- */
.features { display: flex; flex-direction: column; gap: 20rpx; }
.feature-item {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-md);
  gap: 24rpx;
  border: 1rpx solid rgba(200,16,46,0.05);
}
.feature-icon  { font-size: 52rpx; flex-shrink: 0; }
.feature-title { font-size: 30rpx; font-weight: 700; margin-bottom: 8rpx; color: var(--text-primary); font-family: STKaiti, KaiTi, serif; }
.feature-desc  { font-size: 24rpx; color: var(--text-muted); line-height: 1.6; }

/* ---- 录音区 ---- */
.question-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 36rpx;
  box-shadow: var(--shadow-md);
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(200,16,46,0.05);
}
.q-number {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 14rpx;
  font-weight: 500;
}
.q-progress-bar {
  height: 6rpx;
  background: var(--red-pale);
  border-radius: 3rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.q-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--red-primary), var(--gold));
  border-radius: 3rpx;
  transition: width 0.3s ease;
}
.q-text {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.6;
  color: var(--text-primary);
  font-family: STKaiti, KaiTi, serif;
  letter-spacing: 1rpx;
}
/* 显著AI生成提醒 - 问题卡片底部 */
.ai-reminder {
  font-size: 24rpx;
  color: #C8102E;
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: rgba(200, 16, 46, 0.08);
  border-radius: 8rpx;
  border-left: 4rpx solid #C8102E;
  font-weight: 600;
  line-height: 1.5;
}

/* ---- 录音按钮区 ---- */
.record-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}
.record-waves {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 64rpx;
  margin-bottom: 24rpx;
}
.wave {
  width: 8rpx;
  border-radius: 4rpx;
  background: var(--red-primary);
  animation: waveAnim 0.6s ease-in-out infinite alternate;
}
.wave1 { height: 20rpx; animation-delay: 0s; }
.wave2 { height: 40rpx; animation-delay: 0.1s; }
.wave3 { height: 60rpx; animation-delay: 0.2s; }
.wave4 { height: 40rpx; animation-delay: 0.3s; }
.wave5 { height: 20rpx; animation-delay: 0.4s; }
@keyframes waveAnim {
  from { transform: scaleY(0.5); opacity: 0.6; }
  to   { transform: scaleY(1.2); opacity: 1.0; }
}

.record-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 100rpx;
  background: linear-gradient(135deg, var(--red-primary), var(--red-dark));
  box-shadow: 0 8rpx 40rpx rgba(200,16,46,0.4), 0 0 0 16rpx rgba(200,16,46,0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.15s;
}
.record-btn.recording {
  transform: scale(1.10);
  box-shadow: 0 12rpx 60rpx rgba(200,16,46,0.55), 0 0 0 24rpx rgba(200,16,46,0.12);
}
.record-btn-icon { font-size: 64rpx; }
.record-btn-text { font-size: 22rpx; color: #FFFFFF; font-weight: 600; letter-spacing: 1rpx; }
.record-hint     { margin-top: 16rpx; font-size: 24rpx; color: var(--text-muted); }
.record-time     { margin-top: 16rpx; font-size: 44rpx; font-weight: 700; color: var(--red-primary); }

/* ---- 已录列表 ---- */
.recorded-list { width: 100%; }
.recorded-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: var(--radius-md);
  padding: 18rpx 24rpx;
  margin-bottom: 14rpx;
  box-shadow: var(--shadow-sm);
  gap: 16rpx;
  border: 1rpx solid var(--border-light);
}
.ri-num {
  width: 48rpx;
  height: 48rpx;
  background: var(--red-pale);
  color: var(--red-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.ri-q     { flex: 1; font-size: 24rpx; color: var(--text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ri-actions { display: flex; gap: 16rpx; }
.ri-play  { color: var(--red-primary); font-size: 28rpx; }
.ri-del   { color: var(--text-muted); font-size: 24rpx; }

.record-footer { display: flex; gap: 20rpx; margin-top: 32rpx; }

/* ---- 分身展示卡片 ---- */
.avatar-card-wrap {
  padding: 64rpx 40rpx 80rpx;
  display: flex;
  justify-content: center;
}
.avatar-card {
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-xl);
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 600rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
}
.avatar-head    { position: relative; margin-bottom: 20rpx; }
.avatar-photo   {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 6rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.25);
}
.avatar-ai-badge {
  position: absolute;
  bottom: 0; right: -10rpx;
  background: #FFFFFF;
  color: var(--red-primary);
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
  border: 2rpx solid var(--red-primary);
  letter-spacing: 1rpx;
}
.avatar-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 20rpx;
  font-family: STKaiti, KaiTi, serif;
  letter-spacing: 2rpx;
}
.avatar-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}
.avatar-status { display: flex; align-items: center; gap: 10rpx; }
.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
}
.status-dot.online { background: #22c55e; box-shadow: 0 0 8rpx #22c55e; }
.status-text { font-size: 24rpx; color: rgba(255,255,255,0.80); }

/* ---- 功能操作卡片 ---- */
.avatar-actions { display: flex; flex-direction: column; gap: 20rpx; }
.action-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--shadow-md);
  border: 1rpx solid rgba(200,16,46,0.05);
}
.action-card:active { background: var(--red-pale); }
.action-card-left   { display: flex; align-items: center; gap: 24rpx; }
.action-icon  { font-size: 56rpx; }
.action-title { font-size: 30rpx; font-weight: 700; margin-bottom: 6rpx; color: var(--text-primary); font-family: STKaiti, KaiTi, serif; }
.action-desc  { font-size: 24rpx; color: var(--text-muted); }
.action-right { display: flex; align-items: center; gap: 12rpx; }
.free-badge {
  background: #F0FDF4;
  color: #16a34a;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-weight: 700;
  border: 1rpx solid #BBF7D0;
}
.price-badge {
  background: var(--red-pale);
  color: var(--red-primary);
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-weight: 700;
  border: 1rpx solid var(--red-light);
}
.action-arrow { font-size: 40rpx; color: var(--text-light); }

/* ---- 分身动态 ---- */
.activity-list { display: flex; flex-direction: column; gap: 16rpx; }
.activity-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: var(--radius-md);
  padding: 22rpx 28rpx;
  box-shadow: var(--shadow-sm);
  gap: 18rpx;
  border: 1rpx solid var(--border-light);
}
.activity-icon    { font-size: 40rpx; flex-shrink: 0; }
.activity-content { flex: 1; }
.activity-text    { font-size: 26rpx; color: var(--text-primary); display: block; margin-bottom: 4rpx; }
.activity-time    { font-size: 22rpx; color: var(--text-hint); }

/* ---- 推荐官视图：头部 ---- */
.mk-avatar-header {
  padding: 72rpx 48rpx 56rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.mk-ah-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  font-family: STKaiti, KaiTi, serif;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
}
.mk-ah-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  letter-spacing: 1rpx;
}

/* ---- 推荐官视图：分身统计 ---- */
.mk-av-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}
.mkavs-card {
  background: #FFFFFF;
  border-radius: var(--radius-md);
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid rgba(200,16,46,0.05);
}
.mkavs-highlight {
  background: var(--red-pale);
  border-color: var(--red-light);
}
.mkavs-num {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--red-primary);
  font-family: STKaiti, KaiTi, serif;
}
.mkavs-label {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* ---- 推荐官视图：会员分身列表 ---- */
.mk-av-list { margin-top: 16rpx; }
.mkav-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  gap: 18rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}
.mkav-avatar-wrap { position: relative; flex-shrink: 0; }
.mkav-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  border: 3rpx solid var(--border);
}
.mkav-dot {
  position: absolute;
  bottom: 0; right: 0;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 3rpx solid #FFFFFF;
}
.mkav-dot.online { background: #22c55e; }
.mkav-dot.off { background: #D1D5DB; }
.mkav-info { flex: 1; }
.mkav-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}
.mkav-status { font-size: 22rpx; color: var(--text-muted); }
.mkav-right { display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.mkav-time { font-size: 22rpx; color: var(--text-hint); }
.mkav-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  font-weight: 600;
}
.mkav-badge.active {
  background: #F0FDF4;
  color: #16a34a;
  border: 1rpx solid #BBF7D0;
}
.mkav-badge.pending {
  background: #FFF7ED;
  color: #D97706;
  border: 1rpx solid #FDE68A;
}

/* ---- 推荐官视图：引导提示 ---- */
.mkav-guide {
  background: #FFF7ED;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-top: 24rpx;
  border: 1rpx solid rgba(212,160,23,0.12);
}
.mkavg-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--gold-dark);
  margin-bottom: 16rpx;
  font-family: STKaiti, KaiTi, serif;
}
.mkavg-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  padding: 8rpx 0;
  padding-left: 20rpx;
  position: relative;
}
.mkavg-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--gold);
}

/* ---- AI生成内容固定免责声明条 ---- */
.ai-disclaimer-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 32rpx;
  background: #FFF8E1;
  border-top: 1rpx solid #FFE082;
  margin-top: 16rpx;
}
.ai-disclaimer-icon { font-size: 28rpx; flex-shrink: 0; }
.ai-disclaimer-text {
  font-size: 20rpx;
  color: #795548;
  line-height: 1.6;
  flex: 1;
}
