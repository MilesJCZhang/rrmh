<!-- pages/recommender/income/income.wxml - 推荐官收益明细 -->
<view class="page-container">

  <!-- 头部 -->
  <view class="header">
    <view class="header-title">
      <text class="title">💰 收益明细</text>
      <text class="subtitle">实时收益记录，清晰可查</text>
    </view>
    <view class="header-actions">
      <button class="btn-filter" size="mini" bindtap="showFilter">筛选</button>
      <button class="btn-withdraw" size="mini" bindtap="onWithdraw">提现</button>
    </view>
  </view>

  <!-- 收益概览 -->
  <view class="income-summary">
    <view class="summary-card">
      <text class="summary-label">累计收益</text>
      <text class="summary-value">{{totalIncome}}</text>
    </view>
    <view class="summary-card">
      <text class="summary-label">已提现</text>
      <text class="summary-value">{{withdrawn}}</text>
    </view>
    <view class="summary-card">
      <text class="summary-label">可提现</text>
      <text class="summary-value income-green">{{withdrawable}}</text>
    </view>
    <view class="summary-card">
      <text class="summary-label">待结算</text>
      <text class="summary-value income-orange">{{pending}}</text>
    </view>
  </view>

  <!-- 收益统计图表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📊 收益趋势</text>
      <view class="section-tabs">
        <text class="tab-item {{activeTab === 'day' ? 'active' : ''}}" data-tab="day" bindtap="switchTab">日</text>
        <text class="tab-item {{activeTab === 'week' ? 'active' : ''}}" data-tab="week" bindtap="switchTab">周</text>
        <text class="tab-item {{activeTab === 'month' ? 'active' : ''}}" data-tab="month" bindtap="switchTab">月</text>
        <text class="tab-item {{activeTab === 'year' ? 'active' : ''}}" data-tab="year" bindtap="switchTab">年</text>
      </view>
    </view>
    
    <view class="chart-container">
      <view class="chart-placeholder">
        <text class="chart-text">📈 收益趋势图表区域</text>
        <text class="chart-stats">最近7天总收入：{{weekIncome}}</text>
      </view>
    </view>
  </view>

  <!-- 收益来源分布 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📋 收益来源分布</text>
      <text class="section-subtitle">按业务类型统计</text>
    </view>
    
    <view class="income-distribution">
      <view class="distribution-item" wx:for="{{incomeDistribution}}" wx:key="type">
        <view class="distribution-left">
          <view class="distribution-icon">{{item.icon}}</view>
          <view class="distribution-info">
            <text class="distribution-type">{{item.type}}</text>
            <text class="distribution-people">{{item.people}} 人</text>
          </view>
        </view>
        <view class="distribution-right">
          <text class="distribution-amount">{{item.amount}}</text>
          <text class="distribution-percent">{{item.percent}}%</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 收益明细列表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📝 收益记录</text>
      <text class="section-subtitle">共 {{incomeRecords.length}} 条记录</text>
    </view>
    
    <view class="filter-bar">
      <picker class="filter-picker" range="{{filterTypes}}" range-key="label" value="{{filterTypeIndex}}" bindchange="onFilterTypeChange">
        <view class="picker-text">{{filterTypes[filterTypeIndex].label}}</view>
      </picker>
      <picker class="filter-picker" range="{{filterStatus}}" range-key="label" value="{{filterStatusIndex}}" bindchange="onFilterStatusChange">
        <view class="picker-text">{{filterStatus[filterStatusIndex].label}}</view>
      </picker>
      <view class="filter-date" bindtap="selectDate">
        <text class="filter-date-text">{{filterDate || '选择日期'}}</text>
      </view>
    </view>
    
    <view class="income-list">
      <view class="income-item" wx:for="{{filteredRecords}}" wx:key="id">
        <view class="item-left">
          <view class="item-icon">{{item.icon}}</view>
          <view class="item-info">
            <text class="item-type">{{item.type}}</text>
            <text class="item-time">{{item.time}}</text>
            <text class="item-desc">{{item.desc}}</text>
          </view>
        </view>
        <view class="item-right">
          <text class="item-amount {{item.status === 'pending' ? 'income-orange' : 'income-green'}}">
            {{item.amount > 0 ? '+' : ''}}{{item.amount}}
          </text>
          <text class="item-status {{item.status}}">{{item.statusText}}</text>
        </view>
      </view>
    </view>
    
    <view class="empty-placeholder" wx:if="{{filteredRecords.length === 0}}">
      <text class="empty-text">暂无收益记录</text>
      <text class="empty-hint">快去推广获取收益吧！</text>
    </view>
    
    <!-- 分页加载 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <button class="btn-load-more" bindtap="loadMore">
        <text>加载更多</text>
      </button>
    </view>
  </view>

  <!-- 提现记录 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">💳 提现记录</text>
      <button class="btn-mini" size="mini" bindtap="viewAllWithdrawals">查看全部</button>
    </view>
    
    <view class="withdrawal-list">
      <view class="withdrawal-item" wx:for="{{recentWithdrawals}}" wx:key="id">
        <view class="withdrawal-left">
          <text class="withdrawal-id">{{item.id}}</text>
          <text class="withdrawal-time">{{item.time}}</text>
        </view>
        <view class="withdrawal-right">
          <text class="withdrawal-amount">{{item.amount}}</text>
          <text class="withdrawal-status {{item.status}}">{{item.statusText}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 收益规则说明 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📌 收益规则说明</text>
    </view>
    
    <view class="rules-list">
      <view class="rule-item">
        <text class="rule-icon">✅</text>
        <text class="rule-text">会员建档：推荐任意数量均享受99元/人（无首推限制）</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">✅</text>
        <text class="rule-text">推荐联创：第1个无收益，第2个起399元/人</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">✅</text>
        <text class="rule-text">推荐城市合伙人：第1个无，第2个起10000元+永久3%沉淀分红</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">✅</text>
        <text class="rule-text">提现金额满100元即可申请，提现扣除13%平台服务费</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">✅</text>
        <text class="rule-text">提现申请预计1-3个工作日到账</text>
      </view>
    </view>
  </view>

  <!-- 温馨提示 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">💡 提现温馨提示</text>
    </view>
    
    <view class="rules-list">
      <view class="rule-item">
        <text class="rule-icon">⏰</text>
        <text class="rule-text">处理时效：当天15:00前申请的提现，最快次日到账（N+1）</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">📅</text>
        <text class="rule-text">节假日顺延：遇法定节假日（春节、国庆等），到账时间顺延至节后第一个工作日</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">💳</text>
        <text class="rule-text">到账账户：提现金额将转入您申请时填写的微信账户或银行账户</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">💰</text>
        <text class="rule-text">手续费说明：每笔提现收取13%平台服务费（已自动扣除）</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">🔒</text>
        <text class="rule-text">资金安全：提现需通过平台审核，审核通过后由平台统一打款</text>
      </view>
    </view>
  </view>

</view>