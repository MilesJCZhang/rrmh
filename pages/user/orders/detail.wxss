/* pages/user/orders/detail.wxss */
.page-detail { min-height: 100vh; background: #f5f5f5; }

/* 状态头部 */
.status-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  color: #fff;
}
.status-unpaid { background: linear-gradient(135deg, #FF9500, #FF5E3A); }
.status-paid { background: linear-gradient(135deg, #07C160, #059A4A); }
.status-failed { background: linear-gradient(135deg, #999, #666); }
.status-refunded { background: linear-gradient(135deg, #999, #666); }

.status-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.status-text { font-size: 36rpx; font-weight: 600; }

/* 信息卡片 */
.info-card {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 28rpx; color: #999; }
.info-value { font-size: 28rpx; color: #333; }
.info-value.amount { font-size: 32rpx; color: #C8102E; font-weight: 600; }

/* 操作按钮 */
.action-bar {
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.btn-block {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}
.btn-primary {
  background: #C8102E;
  color: #fff;
  border: none;
}
.btn-outline {
  background: #fff;
  color: #C8102E;
  border: 1rpx solid #C8102E;
}
.btn-ghost {
  background: transparent;
  color: #666;
  border: 1rpx solid #ddd;
}

/* 加载/错误状态 */
.loading-state, .error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.loading-state text { font-size: 28rpx; color: #999; }
.error-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.error-text { font-size: 28rpx; color: #999; margin-bottom: 32rpx; }

.safe-bottom { height: 120rpx; }
