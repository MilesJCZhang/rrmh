/* pages/salon/salon.wxss */

/* ---- 返回首页按钮 ---- */
.home-back-btn {
  position: fixed;
  top: calc(var(--status-bar-h, 20px) + 8rpx);
  left: 24rpx;
  z-index: 200;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
}
.home-back-btn:active {
  background: rgba(0, 0, 0, 0.6);
}
.home-back-icon {
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
  margin-top: -4rpx;
}

.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

/* ========== 列表模式 ========== */
.create-btn-wrap {
  margin-bottom: 32rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  text-align: center;
}

.btn-secondary {
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
}

.btn-small {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
}

.btn-text {
  background: none;
  border: none;
  color: #667eea;
  font-size: 28rpx;
  padding: 0;
}

.btn-large {
  width: 100%;
  margin-top: 48rpx;
}

/* 沙龙卡片 */
.salon-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.salon-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.salon-cover {
  width: 100%;
  height: 300rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.salon-cover image {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.6);
  font-size: 28rpx;
}

.salon-info {
  padding: 24rpx;
}

.salon-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.salon-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.tag-primary {
  background: #e8f0fe;
  color: #667eea;
}

.tag-secondary {
  background: #f0f0f0;
  color: #666;
}

.salon-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.salon-detail text {
  display: block;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

.loading-state {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* ========== 创建模式 ========== */
.back-bar {
  margin-bottom: 32rpx;
}

.create-form {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin: 32rpx 0 24rpx;
  display: flex;
  align-items: center;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  border: 2rpx solid #e5e5e5;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.form-textarea {
  border: 2rpx solid #e5e5e5;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-picker {
  border: 2rpx solid #e5e5e5;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
}

.form-row {
  display: flex;
  gap: 24rpx;
}

.form-row .form-group {
  flex: 1;
}

.form-actions {
  margin-top: 32rpx;
}

/* ========== 模板选择 ========== */
.template-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.template-list {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.template-card {
  width: 240rpx;
  min-height: 160rpx;
  background: #f9f9f9;
  border: 4rpx solid transparent;
  border-radius: 12rpx;
  padding: 20rpx;
  position: relative;
  flex-shrink: 0;
}

.template-card.active {
  border-color: #667eea;
  background: #f0f0ff;
}

.template-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.template-desc {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.template-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #667eea;
}

.template-badge {
  position: absolute;
  top: 0;
  right: 0;
  background: #667eea;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 10rpx 0 8rpx;
}

/* ========== 流程列表 ========== */
.process-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.process-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 10rpx;
}

.process-time {
  width: 140rpx;
  font-size: 24rpx;
  color: #667eea;
  font-weight: 500;
  flex-shrink: 0;
}

.process-content {
  flex: 1;
}

.process-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.process-desc {
  font-size: 24rpx;
  color: #666;
}

.process-actions {
  display: flex;
  gap: 16rpx;
}

.action-edit {
  color: #667eea;
  font-size: 24rpx;
}

.action-delete {
  color: #ff4d4f;
  font-size: 24rpx;
}

/* ========== 注意事项列表 ========== */
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.notice-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.notice-bullet {
  color: #667eea;
  font-weight: bold;
}

.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

/* ========== 弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
  text-align: center;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.modal-actions button {
  flex: 1;
}

/* ========== 安全须知 ========== */
.safety-notice {
  background: #fff9f5;
  border: 2rpx solid #ff9800;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.safety-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.safety-icon {
  font-size: 32rpx;
}

.safety-title {
  flex: 1;
  font-size: 28rpx;
  color: #e65100;
  font-weight: 500;
}

.safety-arrow {
  font-size: 28rpx;
  color: #ff9800;
}

.safety-ack {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #ffcc80;
}

.ack-icon {
  color: #4caf50;
  font-size: 28rpx;
  font-weight: bold;
}

.ack-text {
  font-size: 24rpx;
  color: #4caf50;
}

/* 安全须知弹窗 */
.safety-modal {
  max-height: 70vh;
}

.safety-content {
  max-height: 400rpx;
  margin-bottom: 24rpx;
}

.safety-text {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.safety-paragraph {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  text-align: justify;
}

/* ========== 详情页安全须知 ========== */
.detail-page {
  padding: 24rpx;
}

.detail-safety-notice {
  background: #fff9f5;
  border: 2rpx solid #ff9800;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.detail-safety-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.detail-safety-icon {
  font-size: 36rpx;
}

.detail-safety-title {
  font-size: 30rpx;
  color: #e65100;
  font-weight: 600;
}

.detail-safety-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-safety-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* ========== 详情页内容 ========== */
.detail-cover {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.detail-cover image {
  width: 100%;
  height: 100%;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.detail-info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.detail-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-meta-row:last-child {
  border-bottom: none;
}

.detail-meta-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.detail-meta-text {
  font-size: 28rpx;
  color: #333;
}

.detail-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.detail-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.detail-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.detail-process-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-process-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.detail-process-time {
  width: 160rpx;
  font-size: 24rpx;
  color: #667eea;
  font-weight: 500;
  flex-shrink: 0;
}

.detail-process-content {
  flex: 1;
}

.detail-process-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.detail-process-desc {
  font-size: 24rpx;
  color: #999;
}

.detail-notice-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-notice-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.detail-notice-bullet {
  color: #667eea;
  font-weight: bold;
  flex-shrink: 0;
}

.detail-notice-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* ========== 底部报名栏 ========== */
.bottom-placeholder {
  height: 140rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  z-index: 100;
}

.btn-join {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-join[disabled] {
  background: #ccc;
  color: #fff;
}

.btn-joined {
  background: #52c41a !important;
}
