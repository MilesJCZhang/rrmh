/* components/privacy-popup/privacy-popup.wxss */
.privacy-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-dialog {
  background: #fff;
  border-radius: 24rpx;
  width: 620rpx;
  padding: 48rpx 40rpx 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.18);
}

.pd-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 28rpx;
}

.pd-content {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 40rpx;
}

.pd-link {
  color: #C8102E;
  text-decoration: underline;
}

.pd-btns {
  display: flex;
  gap: 24rpx;
}

.pd-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
}

.pd-btn--reject {
  background: #f5f5f5;
  color: #888;
  border: none;
}

.pd-btn--agree {
  background: #C8102E;
  color: #fff;
  border: none;
  margin: 0;
  padding: 0;
  line-height: normal;
}
