/* 活动列表页面样式 */
.activity-list-page {
  background-color: #f8f9fa;
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  background-color: #ffffff;
  padding: 16rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.search-container {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 50rpx;
  padding: 0 32rpx;
  height: 80rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  color: #333;
}

.search-icon {
  font-size: 32rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 筛选标签 */
.filter-tags {
  white-space: nowrap;
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #eee;
}

.tag {
  display: inline-block;
  padding: 12rpx 32rpx;
  margin-right: 20rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f5f5f5;
  border: 1rpx solid #e0e0e0;
}

.tag.active {
  background-color: #C8102E;
  color: #ffffff;
  border-color: #C8102E;
}

/* 活动列表 */
.activity-list {
  padding: 32rpx;
}

.activity-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.activity-header {
  position: relative;
  height: 400rpx;
}

.activity-image {
  width: 100%;
  height: 100%;
}

.activity-status {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}

.activity-status.full {
  background-color: #999;
}

.activity-status.ongoing {
  background-color: #4caf50;
}

.activity-status.upcoming {
  background-color: #2196f3;
}

.activity-price {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background-color: #fff;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #C8102E;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.activity-content {
  padding: 32rpx;
}

.activity-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.activity-meta {
  margin-bottom: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #666;
}

.meta-item .icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

/* 性别比例 */
.gender-ratio {
  margin: 32rpx 0;
  padding: 24rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.ratio-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.ratio-bar {
  display: flex;
  height: 20rpx;
  background-color: #e0e0e0;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.male-ratio {
  background-color: #2196f3;
  height: 100%;
}

.female-ratio {
  background-color: #C8102E;
  height: 100%;
}

.ratio-text {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* 活动标签 */
.activity-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.activity-tags .tag {
  margin: 0 8rpx 8rpx 0;
  padding: 8rpx 20rpx;
  background-color: #f0f7ff;
  color: #2196f3;
  font-size: 24rpx;
  border: none;
}

/* 活动底部 */
.activity-footer {
  padding: 0 32rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
}

.organizer {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.organizer-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.organizer-info {
  flex: 1;
}

.organizer-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.organizer-type {
  font-size: 26rpx;
  color: #999;
}

.action-buttons {
  display: flex;
  justify-content: space-between;
}

.btn-detail,
.btn-join,
.btn-joined {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-detail {
  background-color: #ffffff;
  color: #666;
  border: 1rpx solid #e0e0e0;
  margin-right: 16rpx;
}

.btn-join {
  background-color: #C8102E;
  color: #ffffff;
  border: none;
}

.btn-joined {
  background-color: #f5f5f5;
  color: #999;
  border: none;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  color: #2196f3;
  font-size: 30rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 32rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: #ccc;
}