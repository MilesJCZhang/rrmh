/* subpackages/activity/pages/female-salon-list/female-salon-list.wxss */
/* 女推荐官沙龙列表页 - 玫瑰金商务风 */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF0F5 0%, #F5F7FA 40%);
  padding-bottom: 120rpx;
}

/* ---- 页面头部 ---- */
.page-header {
  background: linear-gradient(135deg, #880E4F 0%, #C2185B 50%, #F06292 100%);
  padding: 48rpx 32rpx 60rpx;
  color: #FFFFFF;
  position: relative;
  overflow: hidden;
}

.page-header::before {
  content: '💼';
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  font-size: 140rpx;
  opacity: 0.12;
  pointer-events: none;
}

.page-header::after {
  content: '';
  position: absolute;
  left: -60rpx;
  bottom: -30rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
  pointer-events: none;
}

.page-header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.page-header-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.header-badges {
  display: flex;
  gap: 16rpx;
}

.badge-item {
  flex: 1;
  background: rgba(255,255,255,0.18);
  backdrop-filter: blur(12rpx);
  border: 1rpx solid rgba(255,255,255,0.25);
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.badge-num {
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
}

.badge-label {
  font-size: 20rpx;
  opacity: 0.8;
  color: #FCE4EC;
}

/* ---- 沙龙卡片列表 ---- */
.salon-cards {
  padding: 20rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: -30rpx;
}

.salon-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(136,14,79,0.06), 0 1rpx 4rpx rgba(136,14,79,0.04);
  border: 1rpx solid rgba(136,14,79,0.08);
  position: relative;
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.salon-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 6rpx; height: 100%;
  background: linear-gradient(180deg, #880E4F, #F06292);
  border-radius: 0 3rpx 3rpx 0;
}

.salon-card:active { transform: scale(0.98); box-shadow: 0 2rpx 10rpx rgba(136,14,79,0.08); }

.sc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.sc-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 状态标签 */
.sc-status-badge {
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.sc-status-badge.status-open {
  color: #880E4F;
  background: #FCE4EC;
  border: 1rpx solid #F48FB1;
}

.sc-status-badge.status-full {
  color: #D32F2F;
  background: #FFEBEE;
  border: 1rpx solid #EF9A9A;
}

.sc-status-badge.status-pending {
  color: #E65100;
  background: #FFF3E0;
  border: 1rpx solid #FFCC80;
}

.sc-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.sc-date { font-weight: 600; color: #1A1A2E; }
.sc-time { color: #888; }
.sc-location { color: #888; }

/* 推荐官席位可视化 */
.sc-recommender-bar {
  background: linear-gradient(135deg, #FFF0F5, #FCE4EC);
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #F8BBD0;
}

.sc-bar-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #880E4F;
  margin-bottom: 12rpx;
}

.sc-slot-dots {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.sc-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #FCE4EC;
  border: 2rpx dashed #F48FB1;
  transition: all 0.2s ease;
}

.sc-dot.filled {
  background: linear-gradient(135deg, #880E4F, #C2185B);
  border: 2rpx solid #880E4F;
  box-shadow: 0 2rpx 6rpx rgba(136,14,79,0.3);
}

.sc-remain-text {
  font-size: 22rpx;
  color: #666;
}

/* 全场人数进度 */
.sc-total-bar {
  background: #F5F7FA;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #E0E0E0;
}

.sc-progress-bg {
  width: 100%;
  height: 12rpx;
  background: #FCE4EC;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.sc-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #880E4F, #F06292);
  border-radius: 6rpx;
  transition: width 0.4s ease;
}

.sc-cap-tip {
  font-size: 20rpx;
  color: #999;
  text-align: center;
}

/* 底部价格+操作 */
.sc-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.sc-price {
  display: flex;
  align-items: baseline;
}

.sc-price-sym {
  font-size: 26rpx;
  font-weight: 700;
  color: #880E4F;
}

.sc-price-num {
  font-size: 42rpx;
  font-weight: 800;
  color: #880E4F;
  line-height: 1;
}

.sc-price-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

.sc-cta {
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #880E4F, #C2185B, #F06292);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 20rpx rgba(136,14,79,0.35);
  transition: all 0.2s ease;
}

.sc-cta:active { opacity: 0.9; transform: scale(0.96); box-shadow: 0 2rpx 10rpx rgba(136,14,79,0.25); }

.sc-cta.sc-cta-disabled {
  background: #E0E0E0;
  color: #999;
  box-shadow: none;
}

.sc-cta.sc-cta-done {
  background: linear-gradient(135deg, #2E7D32, #43A047);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(46,125,50,0.3);
}

/* ---- 加载/空状态 ---- */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon-text {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 30rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
}

/* ---- 推荐官浮动按钮 ---- */
.fab-create {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #880E4F, #C2185B);
  border-radius: 56rpx;
  box-shadow: 0 8rpx 32rpx rgba(136,14,79,0.45);
  z-index: 10;
  transition: transform 0.2s ease;
}

.fab-create:active { transform: scale(0.93); }

.fab-create-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: 700;
  line-height: 1;
}

.fab-create-text {
  font-size: 18rpx;
  color: #FFFFFF;
  font-weight: 500;
  margin-top: 4rpx;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}