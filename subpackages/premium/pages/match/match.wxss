/* subpackages/premium/pages/match/match.wxss */
.page { min-height: 100vh; background: var(--bg-page); padding: 32rpx; }

.loading-wrap { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.loading-spinner {
  width: 80rpx; height: 80rpx; border: 6rpx solid #F0D080;
  border-top-color: #D4A017; border-radius: 50%;
  animation: spin 1s linear infinite; margin-bottom: 24rpx;
}
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: #999; }

.result-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 24rpx; }
.result-icon { font-size: 40rpx; }
.result-title { font-size: 34rpx; font-weight: 700; color: var(--text-primary); font-family: STKaiti, KaiTi, serif; }

.match-card {
  display: flex; gap: 24rpx; padding: 28rpx;
  background: #FFFFFF; border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(160,120,32,0.12);
  border: 1rpx solid rgba(212,160,23,0.15);
  margin-bottom: 24rpx;
}
.match-avatar {
  width: 120rpx; height: 120rpx; border-radius: 60rpx;
  border: 4rpx solid #F0D080; flex-shrink: 0;
}
.match-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.match-name { font-size: 34rpx; font-weight: 700; color: var(--text-primary); }
.match-meta { font-size: 26rpx; color: var(--text-muted); }
.match-score { display: flex; align-items: center; gap: 8rpx; font-size: 24rpx; color: #A07820; }
.score-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.match-occupation { font-size: 24rpx; color: var(--text-muted); }

.match-score-bar { display: flex; align-items: center; gap: 16rpx; margin-bottom: 32rpx; padding: 0 8rpx; }
.msb-label { font-size: 26rpx; color: #999; width: 80rpx; }
.msb-track { flex: 1; height: 12rpx; background: #F0E8D0; border-radius: 6rpx; overflow: hidden; }
.msb-fill { height: 100%; background: linear-gradient(90deg, #D4A017, #A07820); border-radius: 6rpx; transition: width 0.5s; }
.msb-value { font-size: 28rpx; font-weight: 700; color: #A07820; width: 80rpx; text-align: right; }

.match-actions { display: flex; flex-direction: column; gap: 16rpx; }

.confirmed-card {
  display: flex; flex-direction: column; align-items: center; gap: 16rpx;
  padding: 32rpx; background: #FFF8E8; border-radius: 16rpx;
  border: 1rpx solid #F0D080;
}
.confirmed-icon { font-size: 56rpx; }
.confirmed-text { font-size: 32rpx; font-weight: 700; color: #16a34a; }

.no-match {
  display: flex; flex-direction: column; align-items: center; padding-top: 120rpx; gap: 12rpx;
}
.no-match-icon { font-size: 80rpx; margin-bottom: 12rpx; }
.no-match-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); }
.no-match-desc { font-size: 26rpx; color: var(--text-muted); text-align: center; margin-bottom: 24rpx; }
