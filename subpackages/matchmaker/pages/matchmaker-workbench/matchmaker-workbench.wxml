<!-- pages/matchmaker-workbench/matchmaker-workbench.wxml -->
<!-- 推荐官工作台 - 公益推荐官 / 联创推荐官 -->
<view class="page-container">

  <!-- 下拉刷新 -->
  <scroll-view
    scroll-y
    class="scroll-area"
    refresher-enabled="{{true}}"
    refresher-triggered="{{isRefreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onLoadMore"
  >

  <!-- 顶部身份卡 -->
  <view class="hero-card">
    <view class="hero-top">
      <view>
        <text class="hero-title">{{roleLabel}}工作台</text>
        <text class="hero-sub">ID: {{userId}} | 加入: {{joinTime}}</text>
      </view>
      <view class="hero-badge">已激活</view>
    </view>
    <!-- 收益概览四格 -->
    <view class="income-row">
      <view class="income-cell">
        <text class="inc-val">¥{{todayIncome}}</text>
        <text class="inc-lbl">今日收益</text>
      </view>
      <view class="income-cell">
        <text class="inc-val">¥{{monthIncome}}</text>
        <text class="inc-lbl">本月收益</text>
      </view>
      <view class="income-cell">
        <text class="inc-val">¥{{totalIncome}}</text>
        <text class="inc-lbl">累计收益</text>
      </view>
      <view class="income-cell income-cell-highlight" bindtap="onWithdraw">
        <text class="inc-val-highlight">¥{{withdrawable}}</text>
        <text class="inc-lbl">可提现 ›</text>
      </view>
    </view>
  </view>

  <!-- 业务数据统计 -->
  <view class="stats-section">
    <text class="stats-title">📊 业绩数据统计</text>
    <view class="stats-grid">

      <!-- 会员建档统计 -->
      <view class="stat-card" bindtap="onGoMemberList">
        <view class="stat-icon">💑</view>
        <view class="stat-body">
          <text class="stat-num">{{memberStats.count}}</text>
          <text class="stat-lbl">会员建档</text>
        </view>
        <view class="stat-income-wrap">
          <text class="stat-income">+¥{{memberStats.income}}</text>
          <text class="stat-income-lbl">¥99/人</text>
        </view>
      </view>

      <!-- 推荐联创统计（联创推荐官专属） -->
      <view class="stat-card" wx:if="{{partnerStats.count > 0}}" bindtap="onGoEarnings">
        <view class="stat-icon">👑</view>
        <view class="stat-body">
          <text class="stat-num">{{partnerStats.count}}</text>
          <text class="stat-lbl">推荐联创</text>
        </view>
        <view class="stat-income-wrap">
          <text class="stat-income">+¥{{partnerStats.income}}</text>
          <text class="stat-income-lbl">¥399/人②</text>
        </view>
      </view>

      <!-- 沙龙补贴统计（联创推荐官专属） -->
      <view class="stat-card stat-card-highlight" wx:if="{{salonStats.count > 0}}" bindtap="onGoSalon">
        <view class="stat-icon">🎉</view>
        <view class="stat-body">
          <text class="stat-num">{{salonStats.count}}</text>
          <text class="stat-lbl">沙龙补贴</text>
        </view>
        <view class="stat-income-wrap">
          <text class="stat-income">+¥{{salonStats.income}}</text>
          <text class="stat-income-lbl">¥99/次</text>
        </view>
      </view>

    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-section">
    <text class="stats-title">⚡ 快捷操作</text>
    <view class="quick-grid">
      <view class="quick-item" bindtap="onGoQrcode">
        <text class="quick-icon">📱</text>
        <text class="quick-lbl">推广码</text>
      </view>
      <view class="quick-item" bindtap="onGoMemberList">
        <text class="quick-icon">👥</text>
        <text class="quick-lbl">我的会员</text>
      </view>
      <view class="quick-item" bindtap="onGoSalon" wx:if="{{roleLabel === '联创推荐官'}}">
        <text class="quick-icon">🎪</text>
        <text class="quick-lbl">沙龙活动</text>
      </view>
      <view class="quick-item" bindtap="onWithdraw">
        <text class="quick-icon">💸</text>
        <text class="quick-lbl">提现</text>
      </view>
      <view class="quick-item" bindtap="onGoVerify">
        <text class="quick-icon">🪪</text>
        <text class="quick-lbl">实名认证</text>
      </view>
    </view>
  </view>

  <!-- 全局搜索框 -->
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索姓名"
        placeholder-class="search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <!-- 四大分类数据看板 -->
  <view class="dashboard-section">

    <!-- 累计联创推荐官 -->
    <view class="dashboard-card" bindtap="onToggleDetail" data-type="partner_matchmaker">
      <view class="dashboard-header">
        <view class="dashboard-left">
          <text class="dashboard-icon">👑</text>
          <text class="dashboard-label">累计联创推荐官</text>
        </view>
        <view class="dashboard-right">
          <text class="dashboard-count">{{workbenchStats.partner_matchmaker_count || 0}}</text>
          <text class="dashboard-arrow {{expandedType === 'partner_matchmaker' ? 'arrow-up' : ''}}">›</text>
        </view>
      </view>
      <!-- 展开明细 -->
      <view class="dashboard-detail" wx:if="{{expandedType === 'partner_matchmaker'}}">
        <view wx:if="{{detailList.length > 0}}">
          <view class="detail-item" wx:for="{{detailList}}" wx:key="id">
            <view class="detail-left">
              <text class="detail-name">{{item.name || item.nickname || '未设置'}}</text>
              <text class="detail-time">入驻时间：{{item.joinTime || item.created_at || '--'}}</text>
            </view>
            <view class="detail-right">
              <text class="detail-status {{item.status === 'active' ? 'status-active' : 'status-inactive'}}">
                {{item.status === 'active' ? '已激活' : '未激活'}}
              </text>
            </view>
          </view>
          <!-- 加载更多 -->
          <view class="load-more" wx:if="{{hasMore}}" bindtap="onLoadMore">加载更多</view>
          <view class="load-more load-more-end" wx:elif="{{detailList.length > 0}}">— 已加载全部 —</view>
        </view>
        <view class="empty-box" wx:else>
          <text class="empty-text">暂无对应人员数据</text>
        </view>
      </view>
    </view>

    <!-- 累计公益推荐官 -->
    <view class="dashboard-card" bindtap="onToggleDetail" data-type="public_matchmaker">
      <view class="dashboard-header">
        <view class="dashboard-left">
          <text class="dashboard-icon">🤝</text>
          <text class="dashboard-label">累计公益推荐官</text>
        </view>
        <view class="dashboard-right">
          <text class="dashboard-count">{{workbenchStats.public_matchmaker_count || 0}}</text>
          <text class="dashboard-arrow {{expandedType === 'public_matchmaker' ? 'arrow-up' : ''}}">›</text>
        </view>
      </view>
      <!-- 展开明细 -->
      <view class="dashboard-detail" wx:if="{{expandedType === 'public_matchmaker'}}">
        <view wx:if="{{detailList.length > 0}}">
          <view class="detail-item" wx:for="{{detailList}}" wx:key="id">
            <view class="detail-left">
              <text class="detail-name">{{item.name || item.nickname || '未设置'}}</text>
              <text class="detail-time">注册时间：{{item.joinTime || item.created_at || '--'}}</text>
            </view>
          </view>
          <view class="load-more" wx:if="{{hasMore}}" bindtap="onLoadMore">加载更多</view>
          <view class="load-more load-more-end" wx:elif="{{detailList.length > 0}}">— 已加载全部 —</view>
        </view>
        <view class="empty-box" wx:else>
          <text class="empty-text">暂无对应人员数据</text>
        </view>
      </view>
    </view>

    <!-- 累计已注册单身会员 -->
    <view class="dashboard-card" bindtap="onToggleDetail" data-type="registered_member">
      <view class="dashboard-header">
        <view class="dashboard-left">
          <text class="dashboard-icon">💑</text>
          <text class="dashboard-label">累计已注册单身会员</text>
        </view>
        <view class="dashboard-right">
          <text class="dashboard-count">{{workbenchStats.registered_member_count || 0}}</text>
          <text class="dashboard-arrow {{expandedType === 'registered_member' ? 'arrow-up' : ''}}">›</text>
        </view>
      </view>
      <!-- 展开明细 -->
      <view class="dashboard-detail" wx:if="{{expandedType === 'registered_member'}}">
        <view wx:if="{{detailList.length > 0}}">
          <view class="detail-item" wx:for="{{detailList}}" wx:key="id">
            <view class="detail-left">
              <text class="detail-name">{{item.name || item.nickname || '未设置'}}</text>
              <text class="detail-time">注册时间：{{item.joinTime || item.created_at || '--'}}</text>
            </view>
          </view>
          <view class="load-more" wx:if="{{hasMore}}" bindtap="onLoadMore">加载更多</view>
          <view class="load-more load-more-end" wx:elif="{{detailList.length > 0}}">— 已加载全部 —</view>
        </view>
        <view class="empty-box" wx:else>
          <text class="empty-text">暂无对应人员数据</text>
        </view>
      </view>
    </view>

    <!-- 累计未注册访客 -->
    <view class="dashboard-card" bindtap="onToggleDetail" data-type="visitor">
      <view class="dashboard-header">
        <view class="dashboard-left">
          <text class="dashboard-icon">👋</text>
          <text class="dashboard-label">累计未注册访客</text>
        </view>
        <view class="dashboard-right">
          <text class="dashboard-count">{{workbenchStats.visitor_count || 0}}</text>
          <text class="dashboard-arrow {{expandedType === 'visitor' ? 'arrow-up' : ''}}">›</text>
        </view>
      </view>
      <!-- 展开明细 -->
      <view class="dashboard-detail" wx:if="{{expandedType === 'visitor'}}">
        <view wx:if="{{detailList.length > 0}}">
          <view class="detail-item" wx:for="{{detailList}}" wx:key="id">
            <view class="detail-left">
              <text class="detail-name">{{item.visitor_nickname || '访客'}}</text>
              <text class="detail-time">到访时间：{{item.visit_time || '--'}}</text>
            </view>
          </view>
          <view class="load-more" wx:if="{{hasMore}}" bindtap="onLoadMore">加载更多</view>
          <view class="load-more load-more-end" wx:elif="{{detailList.length > 0}}">— 已加载全部 —</view>
        </view>
        <view class="empty-box" wx:else>
          <text class="empty-text">暂无对应人员数据</text>
        </view>
      </view>
    </view>

  </view>

  <!-- 我的推荐 -->
  <view class="referral-section" wx:if="{{myReferrals.length > 0}}">
    <view class="referral-head">
      <text class="referral-title">📊 我的推荐</text>
      <text class="referral-more" bindtap="onGoReferralDetail">查看全部 ›</text>
    </view>
    <view class="referral-list">
      <view class="referral-item" wx:for="{{myReferrals}}" wx:key="id">
        <view class="referral-left">
          <text class="referral-name">{{item.nickname || '未设置'}}</text>
          <text class="referral-wechat">@{{item.wechat_account || '未绑定'}}</text>
        </view>
        <view class="referral-right">
          <text class="referral-date">{{item.dateStr}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 升级入口 -->
  <view class="quick-section" wx:if="{{upgradeTargets.length > 0}}">
    <text class="stats-title">🚀 身份升级</text>
    <view class="upgrade-grid">
      <view
        class="upgrade-item"
        wx:for="{{upgradeTargets}}"
        wx:key="role"
        bindtap="onUpgrade"
        data-role="{{item.role}}"
        data-fee="{{item.fee}}"
        data-label="{{item.label}}"
      >
        <view class="upgrade-icon">{{item.icon}}</view>
        <view class="upgrade-info">
          <text class="upgrade-name">{{item.label}}</text>
          <text class="upgrade-fee" wx:if="{{item.fee > 0}}">¥{{item.fee}}</text>
          <text class="upgrade-fee upgrade-fee-free" wx:else>免费入驻</text>
        </view>
        <text class="upgrade-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 最近收益记录 -->
  <view class="records-section">
    <view class="records-head">
      <text class="stats-title">📝 最近收益记录</text>
      <text class="records-more" bindtap="onGoAllRecords">查看全部 ›</text>
    </view>

    <view wx:if="{{recentRecords.length > 0}}">
      <view class="record-item" wx:for="{{recentRecords}}" wx:key="id">
        <view class="ri-left">
          <text class="ri-icon">{{item.icon}}</text>
          <view class="ri-info">
            <text class="ri-name">{{item.title}}</text>
            <text class="ri-time">{{item.time}}</text>
          </view>
        </view>
        <view class="ri-right">
          <text class="ri-amount">+¥{{item.amount}}</text>
          <text class="ri-status {{item.settled ? 'ri-settled' : 'ri-pending'}}">
            {{item.settled ? '已到账' : '待结算'}}
          </text>
        </view>
      </view>
    </view>

    <view class="empty-box" wx:else>
      <text class="empty-icon">📊</text>
      <text class="empty-text">暂无收益记录</text>
      <text class="empty-sub">推广会员即可产生收益</text>
    </view>
  </view>

  <!-- 收益说明 -->
  <view class="notice-box" wx:if="{{roleLabel === '联创推荐官'}}">
    <text class="notice-title">💡 联创推荐官收益说明</text>
    <view class="notice-list">
      <text class="notice-item">• 推荐会员建档：¥99/人（永久，无首推限制）</text>
      <text class="notice-item">• 推荐联创推荐官：¥399/人（从第2个起有收益）</text>
      <text class="notice-item">• 沙龙补贴：名下会员每次参加沙龙 ¥99/次（永久）</text>
      <text class="notice-item">• 提现扣除13%平台服务费</text>
    </view>
  </view>

  <view class="notice-box" wx:else>
    <text class="notice-title">💡 公益推荐官收益说明</text>
    <view class="notice-list">
      <text class="notice-item">• 推荐会员建档：¥99/人（永久，无首推限制）</text>
      <text class="notice-item">• 升级联创推荐官享沙龙补贴权益（¥99/次）</text>
      <text class="notice-item">• 提现扣除13%平台服务费</text>
    </view>
  </view>

  </scroll-view>
</view>
