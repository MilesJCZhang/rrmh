<!-- pages/user/orders/orders.wxml -->
<view class="page-orders">
  <!-- 状态筛选 -->
  <view class="filter-bar">
    <view
      wx:for="{{statusOptions}}"
      wx:key="value"
      class="filter-item {{statusFilter === item.value ? 'filter-active' : ''}}"
      data-value="{{item.value}}"
      bindtap="onStatusFilter"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{orders.length > 0}}">
    <view
      wx:for="{{orders}}"
      wx:key="id"
      class="order-card"
    >
      <!-- 订单头部：类型 + 状态 -->
      <view class="order-header">
        <view class="order-type">{{item.typeLabel}}</view>
        <text class="order-status {{item.statusClass}}">{{item.statusText}}</text>
      </view>

      <!-- 订单金额 -->
      <view class="order-amount-row">
        <text class="order-amount">{{item.amountDisplay}}</text>
      </view>

      <!-- 订单号和日期 -->
      <view class="order-info">
        <text class="order-no">订单号：{{item.orderNo || item.order_no || item.id}}</text>
        <text class="order-time">{{item.dateText}}</text>
      </view>

      <!-- 操作按钮 -->
      <view class="order-actions">
        <button
          wx:if="{{item.status === 0 || item.status === '0'}}"
          class="btn btn-primary"
          catchtap="onRetryPay"
          data-id="{{item.id || item.orderNo}}"
        >重新支付</button>

        <button
          wx:if="{{(item.status === 1 || item.status === '1') && !item.refunded}}"
          class="btn btn-outline"
          catchtap="onRefund"
          data-order-no="{{item.orderNo}}"
        >申请退款</button>

        <button
          class="btn btn-ghost"
          catchtap="onOrderDetail"
          data-id="{{item.id || item.orderNo}}"
        >查看详情</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无订单</text>
    <text class="empty-desc">还没有订单记录</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="no-more" wx:if="{{!hasMore && orders.length > 0}}">
    <text>— 没有更多订单了 —</text>
  </view>

  <view class="safe-bottom"></view>
</view>
