<!-- pages/help/help.wxml - 帮助与反馈 -->
<view class="page">

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon-text">🔍</text>
      <input
        class="search-input"
        placeholder="搜索常见问题"
        placeholder-style="color: #999;"
        bindinput="onSearchInput"
        value="{{searchKey}}"
      />
      <text class="search-clear" wx:if="{{searchKey}}" bindtap="onClearSearch">×</text>
    </view>
  </view>

  <!-- 分类Tab -->
  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === 'faq' ? 'tab-active' : ''}}"
      bindtap="onSwitchTab"
      data-tab="faq"
    >常见问题</view>
    <view
      class="tab-item {{activeTab === 'feedback' ? 'tab-active' : ''}}"
      bindtap="onSwitchTab"
      data-tab="feedback"
    >意见反馈</view>
  </view>

  <!-- FAQ列表 -->
  <view class="section px-32" wx:if="{{activeTab === 'faq'}}">
    <!-- 常见问题分类 -->
    <view class="faq-group" wx:for="{{filteredFaq}}" wx:key="category">
      <view class="faq-group-title">{{item.category}}</view>
      <view class="faq-item" wx:for="{{item.items}}" wx:for-item="q" wx:key="id" bindtap="onToggleFaq" data-id="{{q.id}}">
        <view class="faq-q">
          <text class="faq-q-text">{{q.question}}</text>
          <text class="faq-arrow {{expandedId === q.id ? 'faq-arrow-open' : ''}}">›</text>
        </view>
        <view class="faq-a" wx:if="{{expandedId === q.id}}">
          <text class="faq-a-text">{{q.answer}}</text>
        </view>
      </view>
    </view>

    <!-- 搜索无结果 -->
    <view class="empty-wrap" wx:if="{{filteredFaq.length === 0 && searchKey}}">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">没有找到相关问题</text>
    </view>
  </view>

  <!-- 意见反馈 -->
  <view class="section px-32" wx:if="{{activeTab === 'feedback'}}">
    <view class="feedback-form">
      <!-- 反馈类型 -->
      <view class="form-label">反馈类型</view>
      <view class="type-tags">
        <view
          class="type-tag {{feedbackType === item.value ? 'type-tag-active' : ''}}"
          wx:for="{{feedbackTypes}}"
          wx:key="value"
          bindtap="onSelectType"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </view>

      <!-- 详细描述 -->
      <view class="form-label">详细描述</view>
      <textarea
        class="form-textarea"
        placeholder="请详细描述您遇到的问题或建议..."
        placeholder-style="color: #bbb;"
        maxlength="500"
        bindinput="onInputDesc"
        value="{{feedbackDesc}}"
        auto-height
      />
      <text class="char-count">{{feedbackDesc.length}}/500</text>

      <!-- 联系方式 -->
      <view class="form-label">联系方式（选填）</view>
      <input
        class="form-input"
        placeholder="微信号/手机号，方便我们联系您"
        placeholder-style="color: #bbb;"
        bindinput="onInputContact"
        value="{{feedbackContact}}"
      />

      <!-- 提交按钮 -->
      <button class="btn btn-primary btn-block btn-lg mt-32" bindtap="onSubmitFeedback" disabled="{{submitting}}">
        {{submitting ? '提交中...' : '提交反馈'}}
      </button>
    </view>

    <!-- 提交成功 -->
    <view class="success-card" wx:if="{{submitted}}">
      <text class="success-icon">✅</text>
      <text class="success-title">感谢您的反馈！</text>
      <text class="success-desc">我们会在1-3个工作日内处理，如有需要会通过您留下的联系方式与您沟通</text>
    </view>
  </view>

  <!-- 联系客服入口（官方客服消息） -->
  <view class="section px-32 mt-24" wx:if="{{activeTab === 'faq'}}">
    <view class="contact-card">
      <view class="contact-icon-wrap">
        <text class="contact-icon-text">💬</text>
      </view>
      <view class="contact-info">
        <view class="contact-title">还是没找到答案？</view>
        <view class="contact-desc">点击下方按钮，在线联系客服为您解答</view>
      </view>
    </view>
    <button
      class="btn btn-primary btn-block mt-16"
      open-type="contact"
      session-from="help-page"
    >💬 联系在线客服</button>
  </view>

  <view class="safe-bottom"></view>
</view>
