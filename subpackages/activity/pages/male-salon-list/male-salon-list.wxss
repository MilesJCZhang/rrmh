/* subpackages/activity/pages/male-salon-list/male-salon-list.wxss */
/* 男推荐官沙龙列表页样式 - 蓝色商务风，与常规沙龙完全隔离 */

.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 120rpx;
}

/* ---- 页面头部 ---- */
.page-header {
  background: linear-gradient(135deg, #1565C0 0%, #42A5F5 100%);
  padding: 48rpx 32rpx 60rpx;
  color: #FFFFFF;
  position: relative;
  overflow: hidden;
}

.page-header::before {
  content: '💼';
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  font-size: 120rpx;
  opacity: 0.1;
  pointer-events: none;
}

.page-header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
}

.page-header-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.header-badges {
  display: flex;
  gap: 16rpx;
}

.badge-item {
  flex: 1;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.badge-num {
  font-size: 28rpx;
  font-weight: 800;
}

.badge-label {
  font-size: 20rpx;
  opacity: 0.75;
}

/* ---- 沙龙卡片列表 ---- */
.salon-cards {
  padding: 20rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: -30rpx; /* 覆盖头部 */
}

.salon-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(21,101,192,0.08);
  border: 1rpx solid rgba(21,101,192,0.1);
  position: relative;
  overflow: hidden;
}

.salon-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 6rpx; height: 100%;
  background: linear-gradient(180deg, #1565C0, #42A5F5);
}

.salon-card:active { transform: scale(0.99); opacity: 0.9; }

.sc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.sc-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 状态标签 */
.sc-status-badge {
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.sc-status-badge.status-open {
  color: #1565C0;
  background: #E3F2FD;
  border: 1rpx solid #1565C0;
}

.sc-status-badge.status-full {
  color: #F44336;
  background: #FFEBEE;
  border: 1rpx solid #F44336;
}

.sc-status-badge.status-pending {
  color: #FF9800;
  background: #FFF8E1;
  border: 1rpx solid #FF9800;
}

.sc-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.sc-date { font-weight: 600; color: #333; }
.sc-time { color: #888; }
.sc-location { color: #888; }

/* 推荐官席位可视化 */
.sc-recommender-bar {
  background: #F8FAFE;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #E3F2FD;
}

.sc-bar-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1565C0;
  margin-bottom: 12rpx;
}

.sc-slot-dots {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.sc-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #E3F2FD;
  border: 2rpx dashed #90CAF9;
}

.sc-dot.filled {
  background: #1565C0;
  border: 2rpx solid #1565C0;
  border-style: solid;
}

.sc-remain-text {
  font-size: 22rpx;
  color: #666;
}

/* 全场人数进度 */
.sc-total-bar {
  background: #F8FAFE;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #E3F2FD;
}

.sc-progress-bg {
  width: 100%;
  height: 16rpx;
  background: #E3F2FD;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.sc-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1565C0, #42A5F5);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.sc-cap-tip {
  font-size: 20rpx;
  color: #999;
  text-align: center;
}

/* 底部价格+操作 */
.sc-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.sc-price {
  display: flex;
  align-items: baseline;
}

.sc-price-sym {
  font-size: 26rpx;
  font-weight: 700;
  color: #1565C0;
}

.sc-price-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #1565C0;
  line-height: 1;
}

.sc-price-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

.sc-cta {
  padding: 14rpx 36rpx;
  background: linear-gradient(135deg, #1565C0, #42A5F5);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 16rpx rgba(21,101,192,0.3);
}

.sc-cta:active { opacity: 0.85; transform: scale(0.96); }

.sc-cta.sc-cta-disabled {
  background: #E0E0E0;
  color: #999;
  box-shadow: none;
}

.sc-cta.sc-cta-done {
  background: #4CAF50;
  color: #FFFFFF;
  box-shadow: none;
}

/* ---- 加载/空状态 ---- */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon-text {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 30rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
}

/* ---- 推荐官浮动按钮 ---- */
.fab-create {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #1565C0, #42A5F5);
  border-radius: 56rpx;
  box-shadow: 0 8rpx 32rpx rgba(21,101,192,0.4);
  z-index: 10;
}

.fab-create:active { transform: scale(0.95); }

.fab-create-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: 700;
  line-height: 1;
}

.fab-create-text {
  font-size: 18rpx;
  color: #FFFFFF;
  font-weight: 500;
  margin-top: 4rpx;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}