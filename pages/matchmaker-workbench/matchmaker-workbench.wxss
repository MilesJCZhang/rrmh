/* pages/matchmaker-workbench/matchmaker-workbench.wxss */
/* 推荐官工作台样式 - 参照城市合伙人工作台 */

.page-container {
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ===== 顶部英雄卡 ===== */
.hero-card {
  background: linear-gradient(135deg, #C8102E, #8B0000);
  padding: 48rpx 32rpx 32rpx;
  color: #fff;
}
.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}
.hero-title {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}
.hero-sub {
  font-size: 22rpx;
  opacity: 0.75;
}
.hero-badge {
  background: rgba(255,255,255,0.25);
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 24rpx;
  padding: 6rpx 22rpx;
  font-size: 22rpx;
  color: #fff;
  flex-shrink: 0;
}

/* 收益四格 */
.income-row {
  display: flex;
  gap: 2rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  overflow: hidden;
}
.income-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  gap: 6rpx;
}
.income-cell-highlight {
  background: rgba(255, 200, 50, 0.25);
}
.inc-val {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}
.inc-val-highlight {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFD700;
}
.inc-lbl {
  font-size: 20rpx;
  color: rgba(255,255,255,0.75);
}

/* ===== 统计区 ===== */
.stats-section,
.quick-section,
.records-section {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 24rpx 16rpx;
}
.stats-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}
.stats-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.stat-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FFF8F8;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  border-left: 6rpx solid #C8102E;
}
.stat-card-highlight {
  background: #FEF9C3;
  border-left-color: #F59E0B;
}
.stat-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}
.stat-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.stat-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #C8102E;
  line-height: 1;
}
.stat-lbl {
  font-size: 22rpx;
  color: #777;
  margin-top: 4rpx;
}
.stat-income-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.stat-income {
  font-size: 28rpx;
  font-weight: 700;
  color: #2E7D32;
}
.stat-income-lbl {
  font-size: 20rpx;
  color: #999;
  margin-top: 2rpx;
}

/* ===== 快捷操作 ===== */
.quick-grid {
  display: flex;
  gap: 16rpx;
}
.quick-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #F8F8F8;
  border-radius: 14rpx;
  padding: 20rpx 8rpx;
  gap: 10rpx;
}
.quick-icon {
  font-size: 40rpx;
}
.quick-lbl {
  font-size: 22rpx;
  color: #555;
}

/* ===== 收益记录 ===== */
.records-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.records-more {
  font-size: 24rpx;
  color: #C8102E;
}
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}
.ri-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.ri-icon {
  font-size: 36rpx;
}
.ri-info {
  display: flex;
  flex-direction: column;
}
.ri-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
.ri-time {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}
.ri-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.ri-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #2E7D32;
}
.ri-status {
  font-size: 20rpx;
  margin-top: 4rpx;
}
.ri-pending { color: #FB8C00; }
.ri-settled { color: #9E9E9E; }

/* 空状态 */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 24rpx;
}
.empty-icon { font-size: 56rpx; margin-bottom: 12rpx; }
.empty-text { font-size: 28rpx; color: #555; }
.empty-sub { font-size: 22rpx; color: #999; margin-top: 8rpx; }

/* ===== 升级入口 ===== */
.upgrade-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.upgrade-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FFF5F5;
  border: 1rpx solid #FFCDD2;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
}
.upgrade-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}
.upgrade-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.upgrade-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.upgrade-fee {
  font-size: 22rpx;
  color: #C8102E;
  margin-top: 4rpx;
}
.upgrade-fee-free {
  color: #2E7D32;
}
.upgrade-arrow {
  font-size: 32rpx;
  color: #C8102E;
  font-weight: bold;
}

/* ===== 说明框 ===== */
.notice-box {
  margin: 24rpx;
  background: #FFF8E1;
  border: 1rpx solid #FFE082;
  border-radius: 16rpx;
  padding: 24rpx;
}
.notice-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #795548;
  display: block;
  margin-bottom: 16rpx;
}
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.notice-item {
  font-size: 24rpx;
  color: #5D4037;
  line-height: 1.6;
}

/* ===== 推荐关系列表 ===== */
.referral-section {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
}
.referral-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.referral-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}
.referral-more {
  font-size: 24rpx;
  color: #C8102E;
}
.referral-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.referral-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}
.referral-item:last-child {
  border-bottom: none;
}
.referral-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.referral-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
.referral-wechat {
  font-size: 20rpx;
  color: #999;
}
.referral-right {
  flex-shrink: 0;
}
.referral-date {
  font-size: 20rpx;
  color: #999;
}
