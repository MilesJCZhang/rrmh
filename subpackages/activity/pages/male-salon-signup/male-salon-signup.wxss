/* subpackages/activity/pages/male-salon-signup/male-salon-signup.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}
.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 600;
}
.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.form-textarea {
  width: 100%;
  min-height: 120rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.form-picker {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  color: #333;
  box-sizing: border-box;
}
radio-group label {
  display: inline-block;
  margin-right: 24rpx;
  font-size: 28rpx;
  color: #333;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1565C0;
  margin: 32rpx 0 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
}
.btn-add-companion {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border: 2rpx dashed #1565C0;
  border-radius: 12rpx;
  color: #1565C0;
  font-size: 28rpx;
  background: #f5f9ff;
  margin-top: 16rpx;
}
.btn-group {
  margin-top: 48rpx;
}
.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}
.btn-primary {
  background: #1565C0;
  color: #fff;
}
.btn-secondary {
  background: #f0f0f0;
  color: #666;
}
