/* ============================================================
   pages/reunion/reunion-chat.wxss
   AI陪伴聊天页 · 紫色专属 + 国风基调
   ============================================================ */
.page { min-height: 100vh; background: var(--bg-page); }

/* ---- 邀请分享 ---- */
.share-page { padding-top: 40rpx; }
.share-poster {
  background: linear-gradient(135deg, #7649A4, #4A2870);
  border-radius: var(--radius-lg);
  padding: 56rpx 36rpx;
  text-align: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(118,73,164,0.4);
  position: relative;
  overflow: hidden;
}
.share-poster::before {
  content: '✦';
  position: absolute;
  right: -20rpx; top: -20rpx;
  font-size: 260rpx;
  color: rgba(255,255,255,0.05);
  pointer-events: none;
}
.poster-emoji  { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.poster-title  { font-size: 40rpx; font-weight: 800; color: #FFFFFF; margin-bottom: 12rpx; font-family: STKaiti, KaiTi, serif; }
.poster-desc   { font-size: 26rpx; color: rgba(255,255,255,0.85); margin-bottom: 32rpx; line-height: 1.6; }
.poster-code {
  background: rgba(255,255,255,0.18);
  border-radius: var(--radius-md);
  padding: 20rpx 32rpx;
  display: inline-block;
  border: 1rpx solid rgba(255,255,255,0.25);
}
.code-label { font-size: 22rpx; color: rgba(255,255,255,0.72); display: block; margin-bottom: 6rpx; }
.code-val   { font-size: 48rpx; font-weight: 900; color: #FFFFFF; letter-spacing: 8rpx; }

.share-tips {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-md);
}
.tip-item {
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-light);
  line-height: 1.7;
}
.tip-item:last-child { border-bottom: none; }

/* ---- 聊天 ---- */
.chat-header-reunion {
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  border-bottom: 1rpx solid var(--border-light);
}
.reunion-avatars {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 12rpx;
}
.r-avatar-wrap { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.r-avatar      { width: 80rpx; height: 80rpx; border-radius: 40rpx; border: 3rpx solid rgba(118,73,164,0.3); }
.r-ai-tag {
  font-size: 18rpx;
  color: #7649A4;
  background: #F5EEFF;
  padding: 2rpx 12rpx;
  border-radius: 100rpx;
  font-weight: 600;
  border: 1rpx solid #D8B4FE;
}
.reunion-heart  { font-size: 40rpx; }
.reunion-status { text-align: center; font-size: 24rpx; color: var(--text-muted); }

.reunion-messages { height: calc(100vh - 200rpx); }
.msg-list  { padding: 24rpx; }
.msg-item  { display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 28rpx; }
.msg-right { flex-direction: row-reverse; }
.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  flex-shrink: 0;
  border: 3rpx solid rgba(118,73,164,0.2);
}
.msg-bubble { padding: 20rpx 24rpx; border-radius: 20rpx; max-width: 560rpx; }
.bubble-left {
  background: #FFFFFF;
  border-top-left-radius: 4rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}
.bubble-right-purple {
  background: linear-gradient(135deg, #7649A4, #4A2870);
  color: #FFFFFF;
  border-top-right-radius: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(118,73,164,0.35);
}
.msg-text { font-size: 28rpx; line-height: 1.7; display: block; }

/* ---- 聊天结果 ---- */
.reunion-result { margin-top: 32rpx; }
.result-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 48rpx;
  text-align: center;
  box-shadow: var(--shadow-md);
  border: 1rpx solid rgba(118,73,164,0.07);
}
.result-icon    { font-size: 80rpx; margin-bottom: 20rpx; display: block; }
.result-title   { font-size: 36rpx; font-weight: 800; margin-bottom: 16rpx; color: var(--text-primary); font-family: STKaiti, KaiTi, serif; }
.result-summary { font-size: 26rpx; color: var(--text-secondary); line-height: 1.7; margin-bottom: 24rpx; text-align: left; }
