/* pages/help/help.wxss - 帮助与反馈 */

.page {
  min-height: 100vh;
  background: var(--bg-page, #f5f5f5);
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 32rpx;
  background: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 100rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}
.search-icon-text {
  font-size: 28rpx;
}
.search-input {
  flex: 1;
  font-size: 26rpx;
  height: 40rpx;
}
.search-clear {
  font-size: 32rpx;
  color: #999;
  padding: 0 8rpx;
}

/* 分类Tab */
.tab-bar {
  display: flex;
  background: #FFFFFF;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--text-muted, #666);
  position: relative;
  font-weight: 500;
}
.tab-active {
  color: #C8102E;
  font-weight: 700;
}
.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #C8102E;
  border-radius: 4rpx;
}

/* FAQ分组 */
.faq-group {
  margin-bottom: 24rpx;
}
.faq-group-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary, #333);
  padding: 20rpx 0 12rpx;
}

/* FAQ条目 */
.faq-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.faq-q {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  gap: 16rpx;
}
.faq-q-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary, #333);
  line-height: 1.5;
}
.faq-arrow {
  font-size: 32rpx;
  color: #ccc;
  transition: transform 0.2s;
  flex-shrink: 0;
}
.faq-arrow-open {
  transform: rotate(90deg);
  color: #C8102E;
}
.faq-a {
  padding: 0 24rpx 24rpx;
  border-top: 1rpx solid #F5F5F5;
}
.faq-a-text {
  font-size: 24rpx;
  color: var(--text-muted, #666);
  line-height: 1.7;
}

/* 搜索空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}
.empty-text {
  font-size: 26rpx;
  color: var(--text-muted, #999);
}

/* 联系客服卡片 */
.contact-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.contact-card:active { opacity: 0.85; }
.contact-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C8102E, #E8454A);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.contact-icon-text {
  font-size: 32rpx;
}
.contact-info { flex: 1; }
.contact-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary, #333);
  margin-bottom: 4rpx;
}
.contact-desc {
  font-size: 22rpx;
  color: var(--text-muted, #999);
}
.contact-arrow {
  font-size: 32rpx;
  color: #ccc;
  flex-shrink: 0;
}

/* ---- 反馈表单 ---- */
.feedback-form {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.form-label {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary, #333);
  margin-bottom: 16rpx;
  margin-top: 20rpx;
}
.form-label:first-child { margin-top: 0; }

/* 类型标签 */
.type-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.type-tag {
  padding: 10rpx 28rpx;
  border-radius: 100rpx;
  background: #F5F5F5;
  font-size: 24rpx;
  color: var(--text-muted, #666);
  font-weight: 500;
}
.type-tag-active {
  background: rgba(200, 16, 46, 0.1);
  color: #C8102E;
  font-weight: 700;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--text-primary, #333);
  line-height: 1.6;
  box-sizing: border-box;
}
.char-count {
  font-size: 20rpx;
  color: #bbb;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 80rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: var(--text-primary, #333);
  box-sizing: border-box;
}

/* 提交成功 */
.success-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx 28rpx;
  text-align: center;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.success-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 16rpx;
}
.success-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary, #333);
  display: block;
  margin-bottom: 12rpx;
}
.success-desc {
  font-size: 24rpx;
  color: var(--text-muted, #666);
  line-height: 1.7;
}
