<!-- subpackages/activity/pages/salon-detail/salon-detail.wxml -->
<!-- 返回按钮（分享/扫码直接进入时显示，色背景固定最上层） -->
<view class="home-back-btn" wx:if="{{showHomeBack}}" bindtap="goBack" style="background: {{themeGradient}};">
  <text class="home-back-icon">‹</text>
</view>

<view class="page {{salonType === 'male_salon' ? 'male-theme' : salonType === 'female_salon' ? 'female-theme' : ''}}" wx:if="{{!loading && salon}}">

  <!-- 顶部封面 -->
  <view class="cover-wrap">
    <view class="cover-bg"></view>
    <view class="cover-body">
      <view class="cover-badge" wx:if="{{salonType === 'male_salon'}}">男推荐官沙龙</view>
      <view class="cover-badge" wx:elif="{{salonType === 'female_salon'}}">女推荐官沙龙</view>
      <view class="cover-badge" wx:else>{{salon.scoreTier === 'gold' ? '优质专场' : salon.scoreTier === 'silver' ? '良好专场' : '综合场'}}</view>
      <view class="cover-title">{{salon.name}}</view>
      <view class="cover-sub">{{salon.location}} | {{salon.eventDate}} {{salon.startTime || ''}}</view>
    </view>
  </view>

  <!-- 3男3女分组可视化（仅常规沙龙显示） -->
  <view class="px-32 mt-24" wx:if="{{salon.isGrouped && !salonType}}">
    <view class="section-label">3男3女分组</view>
    <view class="group-visual-card">
      <view class="gv-row">
        <view class="gv-label">👨 男</view>
        <view class="gv-slots">
          <view class="gv-slot {{maleSlots[0] ? 'filled' : 'empty'}}">
            <text wx:if="{{maleSlots[0]}}">■</text>
            <text wx:else>□</text>
          </view>
          <view class="gv-slot {{maleSlots[1] ? 'filled' : 'empty'}}">
            <text wx:if="{{maleSlots[1]}}">■</text>
            <text wx:else>□</text>
          </view>
          <view class="gv-slot {{maleSlots[2] ? 'filled' : 'empty'}}">
            <text wx:if="{{maleSlots[2]}}">■</text>
            <text wx:else>□</text>
          </view>
        </view>
        <view class="gv-remain">{{maleRemain}}位剩余</view>
      </view>
      <view class="gv-row">
        <view class="gv-label">👩 女</view>
        <view class="gv-slots">
          <view class="gv-slot {{femaleSlots[0] ? 'filled' : 'empty'}}">
            <text wx:if="{{femaleSlots[0]}}">■</text>
            <text wx:else>□</text>
          </view>
          <view class="gv-slot {{femaleSlots[1] ? 'filled' : 'empty'}}">
            <text wx:if="{{femaleSlots[1]}}">■</text>
            <text wx:else>□</text>
          </view>
          <view class="gv-slot {{femaleSlots[2] ? 'filled' : 'empty'}}">
            <text wx:if="{{femaleSlots[2]}}">■</text>
            <text wx:else>□</text>
          </view>
        </view>
        <view class="gv-remain">{{femaleRemain}}位剩余</view>
      </view>
    </view>
  </view>

  <!-- 推荐官沙龙单性别名额（仅推荐官沙龙显示） -->
  <view class="px-32 mt-24" wx:if="{{salonType}}">
    <view class="section-label">{{salonType === 'male_salon' ? '男推荐官名额' : '女推荐官名额'}}</view>
    <view class="group-visual-card">
      <view class="gv-row">
        <view class="gv-label">{{salonType === 'male_salon' ? '👨 男士' : '👩 女士'}}</view>
        <view class="gv-slots">
          <block wx:for="{{recommenderSlots}}" wx:key="index">
            <view class="gv-slot {{item ? 'filled' : 'empty'}}">
              <text wx:if="{{item}}">■</text>
              <text wx:else>□</text>
            </view>
          </block>
        </view>
        <view class="gv-remain">{{recommenderRemain}}位剩余</view>
      </view>
      <view class="gv-cap-tip">含随行，每场共{{salon.totalCap || 27}}人封顶</view>
    </view>
  </view>

  <!-- 核心规格卡片（常规沙龙：3项；推荐官沙龙：2项） -->
  <view class="spec-card" wx:if="{{!salonType}}">
    <view class="spec-row">
      <view class="spec-item">
        <text class="spec-num">{{salon.maxPerGender * 2}}人</text>
        <text class="spec-label">3男3女</text>
      </view>
      <view class="spec-divider"></view>
      <view class="spec-item">
        <text class="spec-num">{{salon.scoreTier === 'all' ? '不限' : salon.scoreTier === 'gold' ? '80+' : salon.scoreTier === 'silver' ? '60+' : '全部'}}</text>
        <text class="spec-label">评分要求</text>
      </view>
      <view class="spec-divider"></view>
      <view class="spec-item">
        <text class="spec-num">¥{{salon.registrationFee}}</text>
        <text class="spec-label">报名费</text>
      </view>
    </view>
  </view>
  <view class="spec-card" wx:else>
    <view class="spec-row">
      <view class="spec-item">
        <text class="spec-num">{{salon.totalCap || 27}}人</text>
        <text class="spec-label">封顶（含随行）</text>
      </view>
      <view class="spec-divider"></view>
      <view class="spec-item">
        <text class="spec-num">¥{{salon.registrationFee}}</text>
        <text class="spec-label">报名费</text>
      </view>
    </view>
  </view>

  <!-- 我的评分等级提示（仅常规沙龙显示） -->
  <view class="px-32 mt-16" wx:if="{{!isRegistered && !salonType}}">
    <view class="tier-hint-card {{canSignup ? 'tier-ok' : 'tier-block'}}">
      <view class="tier-hint-left">
        <text class="tier-hint-icon">{{canSignup ? '✅' : '⚠️'}}</text>
        <view class="tier-hint-info">
          <text class="tier-hint-text" wx:if="{{canSignup}}">您的评分等级: {{tierInfo.label}}（{{myProfileScore}}分），可报名该场次</text>
          <text class="tier-hint-text" wx:else>{{signupBlockReason}}</text>
        </view>
      </view>
      <view class="tier-hint-action" wx:if="{{!canSignup && myScoreTier === 'unrated'}}" bindtap="onGoRegister">
        <text>去建档 →</text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="px-32 mt-24">
    <view class="info-card">
      <view class="info-row">
        <view class="info-icon-wrap info-icon--date"><text class="info-icon-char">日</text></view>
        <view class="info-content">
          <text class="info-label">活动时间</text>
          <text class="info-value">{{salon.eventDate}} {{salon.startTime || ''}} - {{salon.endTime || ''}}</text>
        </view>
      </view>
      <view class="info-row">
        <view class="info-icon-wrap info-icon--location"><text class="info-icon-char">地</text></view>
        <view class="info-content">
          <text class="info-label">活动地点</text>
          <text class="info-value">{{salon.location}}</text>
        </view>
      </view>
      <view class="info-row">
        <view class="info-icon-wrap info-icon--slots"><text class="info-icon-char">额</text></view>
        <view class="info-content">
          <text class="info-label">名额状态</text>
          <view wx:if="{{!salonType}}" class="slots-inline">
            <view class="slots-bar-mini">
              <view class="slots-fill-mini" style="width: {{(salon.maleCount + salon.femaleCount) / (salon.maxPerGender * 2) * 100}}%"></view>
            </view>
            <text class="info-value">已报 {{salon.maleCount + salon.femaleCount}} / {{salon.maxPerGender * 2}} 人</text>
          </view>
          <view wx:else class="slots-inline">
            <view class="slots-bar-mini">
              <view class="slots-fill-mini" style="width: {{(salon.maleCount + salon.femaleCount) / (salon.totalCap || 27) * 100}}%"></view>
            </view>
            <text class="info-value">已报 {{salon.maleCount + salon.femaleCount}} / {{salon.totalCap || 27}} 人（含随行）</text>
          </view>
          <text class="info-sub" wx:if="{{salonRemain > 0}}">
            <text wx:if="{{salonType}}">{{recommenderRemain}}位推荐官名额剩余</text>
            <text wx:else>男{{maleRemain}}位 / 女{{femaleRemain}}位剩余</text>
          </text>
          <text class="info-sub srow-full" wx:else>名额已满</text>
        </view>
      </view>
      <view class="info-row" wx:if="{{salon.host}}">
        <view class="info-icon-wrap info-icon--host"><text class="info-icon-char">娘</text></view>
        <view class="info-content">
          <text class="info-label">活动主持</text>
          <text class="info-value">{{salon.host}}</text>
        </view>
      </view>
      <view class="info-row" wx:if="{{salon.status && salon.status !== 'published' && salon.status !== 'ongoing' && salon.status !== 'open'}}">
        <view class="info-icon-wrap info-icon--status"><text class="info-icon-char">态</text></view>
        <view class="info-content">
          <text class="info-label">审核状态</text>
          <text class="info-value" wx:if="{{salon.status === 'pending_review'}}">待审核</text>
          <text class="info-value status-rejected" wx:elif="{{salon.status === 'rejected'}}">审核未通过</text>
          <text class="info-value" wx:else>{{salon.status}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 服务保障 -->
  <view class="px-32 mt-24">
    <view class="section-label">服务保障</view>
    <view class="highlight-grid">
      <view class="highlight-item" wx:for="{{salon.highlight}}" wx:key="*this">
        <text class="highlight-check">✓</text>
        <text class="highlight-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 活动说明 -->
  <view class="px-32 mt-24" wx:if="{{salon.description}}">
    <view class="section-label">活动说明</view>
    <view class="desc-block"><text>{{salon.description}}</text></view>
  </view>

  <!-- 参与须知 -->
  <view class="px-32 mt-24">
    <view class="section-label">参与须知</view>
    <view class="notice-card">
      <view class="notice-item"><text class="notice-dot"></text><text class="notice-text">需提前预约，按评分段分组</text></view>
      <view class="notice-item"><text class="notice-dot"></text><text class="notice-text"><text wx:if="{{!salonType}}">3男3女固定6人制，深度了解</text><text wx:else>推荐官专属场地，最多{{salon.totalCap || 27}}人封顶（含随行）</text></text></view>
      <view class="notice-item"><text class="notice-dot"></text><text class="notice-text">活动主持全程现场服务</text></view>
      <view class="notice-item"><text class="notice-dot"></text><text class="notice-text">会员资料隐私加密，不对外公开</text></view>
      <view class="notice-item"><text class="notice-dot"></text><text class="notice-text">报名可携带最多2位随行朋友</text></view>
      <view class="notice-item"><text class="notice-dot"></text><text class="notice-text">活动开始前24小时可取消报名</text></view>
    </view>
  </view>

  <!-- 报名资料填写弹窗 -->
  <view class="modal-mask" wx:if="{{showSignupForm}}" catchtap="closeSignupForm">
    <view class="modal-content" catchtap="preventModalClose">
      <view class="modal-title">填写报名资料</view>

      <!-- 必填：姓名 -->
      <view class="form-group">
        <view class="form-label">姓名 *</view>
        <input class="form-input" placeholder="请输入姓名" value="{{signupForm.name}}" bindinput="onSignupNameInput" />
      </view>

      <!-- 必填：手机号码 -->
      <view class="form-group">
        <view class="form-label">手机号码 *</view>
        <input class="form-input" type="number" placeholder="请输入手机号" value="{{signupForm.mobile}}" bindinput="onSignupMobileInput" />
      </view>

      <!-- 选填：性别 -->
      <view class="form-group">
        <view class="form-label">性别</view>
        <picker mode="selector" range="{{genderOptions}}" value="{{signupForm.genderIndex}}" bindchange="onSignupGenderChange">
          <view class="form-picker">{{signupForm.gender || '请选择'}}</view>
        </picker>
      </view>

      <!-- 选填：年龄 -->
      <view class="form-group">
        <view class="form-label">年龄</view>
        <input class="form-input" type="number" placeholder="请输入年龄" value="{{signupForm.age}}" bindinput="onSignupAgeInput" />
      </view>

      <!-- 选填：所在行业 -->
      <view class="form-group">
        <view class="form-label">所在行业</view>
        <input class="form-input" placeholder="如：互联网、金融" value="{{signupForm.industry}}" bindinput="onSignupIndustryInput" />
      </view>

      <!-- 选填：身份属性 -->
      <view class="form-group">
        <view class="form-label">身份属性</view>
        <radio-group bindchange="onSignupIdentityChange">
          <label><radio value="上班族" checked="{{signupForm.identity === '上班族'}}" />上班族</label>
          <label><radio value="个体老板" checked="{{signupForm.identity === '个体老板'}}" />个体老板</label>
          <label><radio value="自由职业" checked="{{signupForm.identity === '自由职业'}}" />自由职业</label>
          <label><radio value="其他" checked="{{signupForm.identity === '其他'}}" />其他</label>
        </radio-group>
      </view>

      <!-- 选填：上班岗位/职务 -->
      <view class="form-group">
        <view class="form-label">岗位/职务</view>
        <input class="form-input" placeholder="如：工程师、销售总监" value="{{signupForm.position}}" bindinput="onSignupPositionInput" />
      </view>

      <!-- 选填：经营主营项目 -->
      <view class="form-group">
        <view class="form-label">经营主营项目</view>
        <textarea class="form-textarea" placeholder="个体老板填写主营产品、主营业务" value="{{signupForm.business}}" bindinput="onSignupBusinessInput" />
      </view>

      <!-- 选填：个人优势/资源简介 -->
      <view class="form-group">
        <view class="form-label">个人优势/资源简介</view>
        <textarea class="form-textarea" placeholder="简短自我介绍" value="{{signupForm.advantage}}" bindinput="onSignupAdvantageInput" />
      </view>

      <!-- 随行人员 -->
      <view class="section-title mt-16">随行人员（最多2人）</view>
      <view wx:for="{{signupForm.companions}}" wx:key="index">
        <view class="form-group">
          <view class="form-label">随行{{index+1}}姓名 *</view>
          <input class="form-input" placeholder="请输入姓名" value="{{item.name}}" data-index="{{index}}" bindinput="onSignupCompanionNameInput" />
        </view>
        <view class="form-group">
          <view class="form-label">随行{{index+1}}手机 *</view>
          <input class="form-input" type="number" placeholder="请输入手机号" value="{{item.mobile}}" data-index="{{index}}" bindinput="onSignupCompanionMobileInput" />
        </view>
        <view class="form-group" wx:if="{{item.name}}">
          <view class="form-label">随行{{index+1}}性别</view>
          <picker mode="selector" range="{{genderOptions}}" value="{{item.genderIndex}}" data-index="{{index}}" bindchange="onSignupCompanionGenderChange">
            <view class="form-picker">{{item.gender || '请选择'}}</view>
          </picker>
        </view>
      </view>
      <button bindtap="addSignupCompanion" wx:if="{{signupForm.companions.length < 2}}" class="btn-add-companion">+ 添加随行人员</button>

      <view class="modal-actions mt-24">
        <button class="btn btn-secondary" bindtap="closeSignupForm">取消</button>
        <button class="btn btn-primary" bindtap="submitSignupForm" loading="{{submitting}}">{{salon.registrationFee > 0 ? '支付并报名' : '确认报名'}}</button>
      </view>
    </view>
  </view>

  <!-- 随行人员填写区域（未报名时） -->
  <view class="px-32 mt-24" wx:if="{{!isRegistered && canSignup && !showSignupForm}}">
    <view class="section-label">随行人员（选填，最多2人）</view>
    <view class="companions-card">
      <view class="companion-row" wx:for="{{companions}}" wx:key="index">
        <text class="companion-label">随行{{index + 1}}</text>
        <input class="companion-input" placeholder="请输入姓名" value="{{item.name}}" data-index="{{index}}" bindinput="onCompanionInput" />
        <view class="companion-remove" data-index="{{index}}" bindtap="removeCompanion"><text>✕</text></view>
      </view>
      <view class="companion-add" bindtap="addCompanion" wx:if="{{companions.length < 3}}">
        <text class="companion-add-icon">+</text>
        <text class="companion-add-text">添加随行人员</text>
      </view>
    </view>
  </view>

  <!-- 我的报名信息（已报名时） -->
  <view class="px-32 mt-24" wx:if="{{isRegistered && myRegistration}}">
    <view class="section-label">我的报名</view>
    <view class="my-reg-card">
      <view class="my-reg-row">
        <text class="my-reg-label">状态</text>
        <text class="my-reg-value">{{myRegistration.status === 'registered' ? '已报名' : myRegistration.status === 'checked_in' ? '已签到' : myRegistration.status}}</text>
      </view>
      <view class="my-reg-row" wx:if="{{myRegistration.group_index}}">
        <text class="my-reg-label">分组</text>
        <text class="my-reg-value">第{{myRegistration.group_index}}组 ({{myRegistration.group_tier || myRegistration.user_score_tier}})</text>
      </view>
      <view class="my-reg-row" wx:if="{{myRegistration.companionsText}}">
        <text class="my-reg-label">随行人员</text>
        <text class="my-reg-value">{{myRegistration.companionsText}}</text>
      </view>
    </view>
  </view>

  <!-- 咨询 -->
  <view class="px-32 mt-24 mb-160">
    <button class="btn btn-outline btn-block" open-type="contact" session-from="salon-detail">💬 咨询客服</button>
  </view>

  <!-- 底部操作栏 -->
  <view class="footer-bar">
    <view class="footer-inner safe-bottom">
      <view class="footer-price">
        <text wx:if="{{salon.registrationFee > 0}}">
          <text class="price-symbol">¥</text>
          <text class="price-num">{{salon.registrationFee}}</text>
          <text class="price-unit">/人</text>
        </text>
        <text wx:else class="price-free">免费</text>
      </view>

      <!-- 已报名 -->
      <button class="btn btn-cancel-reg footer-btn" bindtap="onCancelRegistration" wx:if="{{isRegistered}}">取消报名</button>

      <!-- 创建者发布 -->
      <button class="btn btn-primary footer-btn" bindtap="onPublishSalon" wx:elif="{{isCreator && salon.status === 'pending_review'}}">发布沙龙</button>

      <!-- 报名按钮 -->
      <button class="btn btn-primary btn-block footer-btn" bindtap="onSignup" loading="{{signing}}" disabled="{{signing || !canSignup}}" wx:elif="{{!isRegistered && (salon.status === 'published' || salon.status === 'open')}}">
        {{!canSignup ? signupBlockReason : '立即报名'}}
      </button>

      <!-- 其他状态 -->
      <view class="footer-status-text" wx:else>
        <text wx:if="{{salon.status === 'pending_review'}}">等待审核</text>
        <text wx:elif="{{salon.status === 'rejected'}}">审核未通过</text>
        <text wx:elif="{{salon.status === 'full'}}">名额已满</text>
        <text wx:elif="{{salon.status === 'completed'}}">活动已结束</text>
        <text wx:else>{{salon.status}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 加载中 -->
<view class="loading-wrap" wx:if="{{loading}}">
  <view class="loading-text">加载中...</view>
</view>

<!-- 无数据 -->
<view class="empty-wrap" wx:if="{{!loading && !salon}}">
  <text class="empty-text">活动不存在或已下架</text>
</view>
