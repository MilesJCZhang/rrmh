<view class="page">
  <view class="form-card">

    <view class="form-group">
      <view class="form-label">姓名 *</view>
      <input class="form-input" placeholder="请输入姓名" value="{{name}}" bindinput="onSignupNameInput" />
    </view>

    <view class="form-group">
      <view class="form-label">手机号码 *</view>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{mobile}}" bindinput="onSignupMobileInput" />
    </view>

    <view class="form-group">
      <view class="form-label">性别</view>
      <picker mode="selector" range="{{genderOptions}}" value="{{genderIndex}}" bindchange="onSignupGenderChange">
        <view class="form-picker">{{gender || '请选择'}}</view>
      </picker>
    </view>

    <view class="form-group">
      <view class="form-label">年龄</view>
      <input class="form-input" type="number" placeholder="请输入年龄" value="{{age}}" bindinput="onSignupAgeInput" />
    </view>

    <view class="form-group">
      <view class="form-label">所在行业</view>
      <input class="form-input" placeholder="如：互联网、金融" value="{{industry}}" bindinput="onSignupIndustryInput" />
    </view>

    <view class="form-group">
      <view class="form-label">身份属性</view>
      <radio-group bindchange="onSignupIdentityChange">
        <label><radio value="上班族" checked="{{identity === '上班族'}}" />上班族</label>
        <label><radio value="个体老板" checked="{{identity === '个体老板'}}" />个体老板</label>
        <label><radio value="自由职业" checked="{{identity === '自由职业'}}" />自由职业</label>
        <label><radio value="其他" checked="{{identity === '其他'}}" />其他</label>
      </radio-group>
    </view>

    <view class="form-group">
      <view class="form-label">岗位/职务</view>
      <input class="form-input" placeholder="如：工程师、销售总监" value="{{position}}" bindinput="onSignupPositionInput" />
    </view>

    <view class="form-group">
      <view class="form-label">经营主营项目</view>
      <textarea class="form-textarea" placeholder="个体老板填写主营产品、主营业务" value="{{business}}" bindinput="onSignupBusinessInput" />
    </view>

    <view class="form-group">
      <view class="form-label">个人优势/资源简介</view>
      <textarea class="form-textarea" placeholder="简短自我介绍" value="{{advantage}}" bindinput="onSignupAdvantageInput" />
    </view>

    <view class="section-title">随行人员（最多2人）</view>
    <view wx:for="{{companions}}" wx:key="index">
      <view class="form-group">
        <view class="form-label">随行{{index+1}}姓名 *</view>
        <input class="form-input" placeholder="请输入姓名" value="{{item.name}}" data-index="{{index}}" bindinput="onSignupCompanionNameInput" />
      </view>
      <view class="form-group">
        <view class="form-label">随行{{index+1}}手机 *</view>
        <input class="form-input" type="number" placeholder="请输入手机号" value="{{item.mobile}}" data-index="{{index}}" bindinput="onSignupCompanionMobileInput" />
      </view>
      <view class="form-group" wx:if="{{item.name}}">
        <view class="form-label">随行{{index+1}}性别</view>
        <picker mode="selector" range="{{genderOptions}}" value="{{item.genderIndex}}" data-index="{{index}}" bindchange="onSignupCompanionGenderChange">
          <view class="form-picker">{{item.gender || '请选择'}}</view>
        </picker>
      </view>
    </view>
    <button bindtap="addSignupCompanion" wx:if="{{companions.length < 2}}" class="btn-add-companion">+ 添加随行人员</button>

    <view class="btn-group">
      <button class="btn btn-primary" bindtap="submitSignupForm" loading="{{loading}}">确认报名</button>
      <button class="btn btn-secondary" bindtap="goBack">取消</button>
    </view>
  </view>
</view>
