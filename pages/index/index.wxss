  bottom: 60rpx;
  left: -20rpx;
}
.salon-poster--elegant .sp-deco-3 {
  width: 60rpx;
  height: 60rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 50%;
  top: 40%;
  right: 120rpx;
}

/* --- 主题：户外绿 --- */
.salon-poster--outdoor {
  background: linear-gradient(135deg, #1A8B5C 0%, #2EAD76 50%, #5CD89A 100%);
}
.salon-poster--outdoor .sp-deco-1 {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  bottom: -40rpx;
  right: 80rpx;
}
.salon-poster--outdoor .sp-deco-2 {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.07);
  top: 20rpx;
  right: -20rpx;
}
.salon-poster--outdoor .sp-deco-3 {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  top: 30%;
  left: -40rpx;
}

/* 装饰圆圈 */
.sp-deco {
  position: absolute;
  pointer-events: none;
}

/* 背景大 emoji 装饰 */
.sp-pattern {
  position: absolute;
  right: 60rpx;
  top: 20%;
  font-size: 100rpx;
  opacity: 0.15;
  transform: rotate(-15deg);
  pointer-events: none;
}

/* 右侧大字 */
.sp-big-char {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 130rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.1);
  line-height: 1;
  pointer-events: none;
}

/* 内容区 */
.sp-content {
  position: relative;
  z-index: 2;
  width: 65%;
}

/* 标签 */
.sp-tag {
  display: inline-block;
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

/* 标题 */
.sp-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 4rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

/* 副标题 */
.sp-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 10rpx;
  font-weight: 500;
}

/* 信息行 */
.sp-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}
.sp-info-item {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}
.sp-info-sep {
  margin: 0 12rpx;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 价格行 */
.sp-price-row {
  display: flex;
  align-items: baseline;
}
.sp-price {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFFFFF;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}
.sp-price-unit {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 4rpx;
}

/* 底部 CTA */
.sp-cta {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
.sp-cta-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}
.sp-cta-arrow {
  font-size: 28rpx;
  color: #FFFFFF;
  margin-left: 8rpx;
  font-weight: 700;
}

/* 点击反馈 */
.salon-poster:active {
  opacity: 0.92;
  transform: scale(0.98);
  transition: all 150ms ease;
}

/* 空状态 */
.salon-empty {
  height: 200rpx;
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm);
}
