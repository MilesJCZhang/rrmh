/* pages/user/orders/orders.wxss */
.page-orders { min-height: 100vh; background: #f8f9fa; }

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}
.filter-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 16rpx 0;
  margin: 0 8rpx;
  border-radius: 32rpx;
  background: #f5f5f5;
  transition: all 0.2s;
}
.filter-active {
  color: #fff;
  background: #C8102E;
  font-weight: 600;
}

/* 订单列表 */
.order-list { padding: 20rpx; }
.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* 订单头部：类型 + 状态 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.order-type {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}
.order-status {
  font-size: 24rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
}
.status-unpaid {
  color: #C8102E;
  background: rgba(200, 16, 46, 0.08);
}
.status-paid {
  color: #C8102E;
  background: rgba(7, 193, 96, 0.08);
}
.status-failed {
  color: #999;
  background: rgba(153, 153, 153, 0.08);
}
.status-refunded {
  color: #999;
  background: rgba(153, 153, 153, 0.08);
}

/* 金额行 */
.order-amount-row {
  margin-bottom: 20rpx;
}
.order-amount {
  font-size: 48rpx;
  color: #C8102E;
  font-weight: 700;
}

/* 订单信息 */
.order-info {
  padding: 20rpx 0;
  border-top: 1rpx solid #f5f5f5;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 20rpx;
}
.order-no {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.order-time {
  display: block;
  font-size: 24rpx;
  color: #bbb;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}
.btn {
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  line-height: 1.5;
  margin: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 140rpx;
}
.btn::after { border: none; }

.btn-primary {
  background: #C8102E;
  color: #fff;
}
.btn-outline {
  background: #fff;
  color: #C8102E;
  border: 1rpx solid #C8102E;
}
.btn-ghost {
  background: #f5f5f5;
  color: #666;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: #333; font-weight: 500; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #999; }

/* 加载状态 */
.loading-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: #999;
}
.no-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #ccc;
}

.safe-bottom { height: 60rpx; }
