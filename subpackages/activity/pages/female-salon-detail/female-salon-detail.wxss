/* subpackages/activity/pages/female-salon-detail/female-salon-detail.wxss */
/* 女推荐官沙龙详情页样式 - 粉色商务风，与常规沙龙完全隔离 */

/* ---- 返回首页按钮（分享/扫码直接进入时显示，主题色背景，最上层） ---- */
.home-back-btn {
  position: fixed;
  top: calc(var(--status-bar-h, 20px) + 8rpx);
  left: 24rpx;
  z-index: 999;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
}

.home-back-btn:active {
  opacity: 0.85;
  transform: scale(0.95);
}

.home-back-icon {
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
  margin-top: -4rpx;
}

.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 160rpx;
}

/* ---- 封面 ---- */
.cover-wrap {
  position: relative;
  width: 100%;
  height: 400rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #C2185B, #F06292);
}

.cover-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 80% 20%, rgba(255,255,255,0.12) 0%, transparent 60%);
  pointer-events: none;
}

.cover-body {
  position: relative;
  z-index: 2;
  padding: 24rpx 32rpx;
  padding-top: calc(var(--status-bar-h, 20px) + 8rpx);
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.cover-badge {
  display: inline-block;
  background: rgba(255,255,255,0.25);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  margin-bottom: 16rpx;
  align-self: flex-start;
}

.cover-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.3;
  margin-bottom: 6rpx;
}

.cover-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

/* ---- 推荐官席位可视化 ---- */
.group-visual-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(194,24,91,0.08);
  border: 1rpx solid rgba(194,24,91,0.1);
}

.gv-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 12rpx 0;
}

.gv-row + .gv-row {
  border-top: 1rpx solid #F5F0F0;
  margin-top: 8rpx;
  padding-top: 20rpx;
}

.gv-label {
  font-size: 28rpx;
  font-weight: 700;
  width: 160rpx;
  flex-shrink: 0;
  color: #C2185B;
}

.gv-slots {
  display: flex;
  gap: 16rpx;
  flex: 1;
  flex-wrap: wrap;
}

.gv-slot {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.gv-slot.filled {
  background: #FCE4EC;
  color: #C2185B;
  border: 2rpx solid #C2185B;
}

.gv-slot.empty {
  background: #FAFAFA;
  color: #DDD;
  border: 2rpx dashed #E0E0E0;
}

.gv-remain {
  font-size: 24rpx;
  color: #666;
  width: 120rpx;
  text-align: right;
  flex-shrink: 0;
}

.gv-cap-tip {
  font-size: 20rpx;
  color: #999;
  text-align: center;
  margin-top: 6rpx;
}

/* ---- 全场人数进度 ---- */
.progress-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(194,24,91,0.08);
  border: 1rpx solid rgba(194,24,91,0.1);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #C2185B;
}

.progress-count {
  font-size: 24rpx;
  font-weight: 700;
  color: #C2185B;
}

.progress-bar-bg {
  width: 100%;
  height: 16rpx;
  background: #F8BBD0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #C2185B, #F06292);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-tip {
  font-size: 20rpx;
  color: #999;
  text-align: center;
}

/* ---- 核心规格卡片 ---- */
.spec-card {
  margin: -24rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 2;
}

.spec-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.spec-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.spec-num {
  font-size: 30rpx;
  font-weight: 800;
  color: #C2185B;
}

.spec-label {
  font-size: 20rpx;
  color: #999;
}

.spec-divider {
  width: 1rpx;
  height: 60rpx;
  background: #F0E8E0;
}

/* ---- 信息卡片 ---- */
.info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.info-row + .info-row {
  border-top: 1rpx solid #F0E8E0;
}

.info-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.info-icon--date {
  background: #FFF0F0;
}

.info-icon--location {
  background: #F0FFF4;
}

.info-icon--slots {
  background: #EEF4FF;
}

.info-icon--host {
  background: #FFF8EE;
}

.info-icon--status {
  background: #FFF8E1;
}

.info-icon-char {
  font-size: 24rpx;
  font-weight: 700;
  color: #C2185B;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.info-label {
  font-size: 22rpx;
  color: #A08070;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.info-sub {
  font-size: 24rpx;
  color: #A08070;
}

.info-sub.row-full {
  color: #C2185B;
  font-weight: 700;
}

.status-rejected {
  color: #E53935 !important;
}

/* 名额内联 */
.slots-in-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.slots-bar-mini {
  width: 120rpx;
  height: 8rpx;
  background: #F0E8E0;
  border-radius: 4rpx;
  overflow: hidden;
}

.slots-fill-mini {
  height: 100%;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #C2185B, #F06292);
}

/* ---- 通用段落标题 ---- */
.section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 20rpx;
}

/* ---- 服务保障 ---- */
.highlight-grid {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.highlight-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.highlight-check {
  color: #C2185B;
  font-weight: 700;
  font-size: 26rpx;
  flex-shrink: 0;
}

.highlight-text {
  font-size: 26rpx;
  color: #333333;
}

/* ---- 活动说明 ---- */
.desc-block {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  font-size: 28rpx;
  color: #333333;
  line-height: 1.9;
  white-space: pre-wrap;
}

/* ---- 参与须知 ---- */
.notice-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.notice-item:last-child {
  margin-bottom: 0;
}

.notice-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #C2185B;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
}

/* ---- 随行人员卡片 ---- */
.companions-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.companion-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F5F0F0;
}

.companion-row:last-of-type {
  border-bottom: none;
}

.companion-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  width: 80rpx;
}

.companion-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 12rpx 16rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  border: 1rpx solid #F0E8E0;
}

.companion-remove {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
  flex-shrink: 0;
}

.companion-remove:active {
  color: #C2185B;
}

.companion-add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  color: #C2185B;
}

.companion-add:active {
  opacity: 0.7;
}

.companion-add-icon {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.companion-add-text {
  font-size: 26rpx;
  font-weight: 600;
}

/* ---- 我的报名信息 ---- */
.my-reg-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.my-reg-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.my-reg-row + .my-reg-row {
  border-top: 1rpx solid #F5F0F0;
}

.my-reg-label {
  font-size: 26rpx;
  color: #999;
}

.my-reg-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* ---- 底部操作栏 ---- */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.footer-inner {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 32rpx;
}

.footer-price {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
}

.price-symbol {
  font-size: 26rpx;
  font-weight: 700;
  color: #C2185B;
}

.price-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #C2185B;
  line-height: 1;
}

.price-unit {
  font-size: 22rpx;
  color: #A08070;
  margin-left: 4rpx;
}

.price-free {
  font-size: 36rpx;
  font-weight: 800;
  color: #4CAF50;
  line-height: 1;
}

.footer-btn {
  flex: 1;
  min-height: 88rpx;
  padding: 10rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1.4;
  border-radius: 44rpx;
  text-align: center;
  white-space: normal;
  word-break: break-all;
}

.btn-primary {
  background: linear-gradient(135deg, #C2185B, #F06292);
  color: #FFFFFF;
}

.btn-cancel-reg {
  background: #FFFFFF;
  color: #C2185B;
  border: 2rpx solid #C2185B;
  font-weight: 600;
}

.footer-status-text {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

/* ---- 加载/空态 ---- */
.loading-wrap,
.empty-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text,
.empty-text {
  font-size: 28rpx;
  color: #A08070;
}

/* ---- 报名资料弹窗 ---- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 32rpx;
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 28rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.modal-actions .btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.modal-actions .btn-secondary {
  background: #F5F0F0;
  color: #666;
}

.modal-actions .btn-primary {
  background: linear-gradient(135deg, #C2185B, #F06292);
  color: #FFFFFF;
}

.modal-actions .btn-primary[loading] {
  opacity: 0.7;
}

/* 表单 */
.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 76rpx;
  background: #FAFAFA;
  border: 1rpx solid #F0E8E0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 100rpx;
  background: #FAFAFA;
  border: 1rpx solid #F0E8E0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  background: #FAFAFA;
  border: 1rpx solid #F0E8E0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

radio-group {
  display: flex;
  gap: 24rpx;
  padding: 12rpx 0;
}

radio-group label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #555;
}

/* 随行人员（弹窗内） */
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-top: 24rpx;
  margin-bottom: 16rpx;
}

.btn-add-companion {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 0;
  color: #C2185B;
  font-size: 26rpx;
  font-weight: 600;
}

/* ---- 通用辅助 ---- */
.px-32 { padding-left: 32rpx; padding-right: 32rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-16 { margin-top: 16rpx; }
.mb-160 { margin-bottom: 160rpx; }
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}