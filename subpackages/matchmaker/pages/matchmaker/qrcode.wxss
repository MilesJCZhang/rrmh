/* pages/matchmaker/qrcode.wxss */
.page { min-height: 100vh; background: var(--bg-page); padding-bottom: 40rpx; }
.qrcode-page { padding-top: 32rpx; }
.qr-card { background: #fff; border-radius: var(--radius-lg); padding: 40rpx; box-shadow: var(--shadow); }
.qr-header { text-align: center; margin-bottom: 32rpx; }
.qr-title { font-size: 36rpx; font-weight: 800; display: block; margin-bottom: 8rpx; }
.qr-desc { font-size: 26rpx; color: var(--text-secondary); }
.poster-preview { margin-bottom: 24rpx; border-radius: var(--radius-md); overflow: hidden; background: #f8f8f8; }
.poster-img { width: 100%; min-height: 400rpx; }
.matchmaker-id {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: var(--bg-page);
  border-radius: var(--radius-md);
}
.id-label { font-size: 24rpx; color: var(--text-secondary); }
.id-val { font-size: 28rpx; font-weight: 700; color: var(--text-primary); flex: 1; }
.id-copy { font-size: 24rpx; color: var(--primary); }
.tips-card { background: #fff; border-radius: var(--radius-lg); padding: 32rpx; box-shadow: var(--shadow); }
.tips-title { font-size: 30rpx; font-weight: 700; margin-bottom: 20rpx; }
.tip-line { font-size: 26rpx; color: var(--text-secondary); padding: 8rpx 0; border-bottom: 1rpx solid var(--border); line-height: 1.6; }
.tip-line:last-child { border-bottom: none; }

/* ─── 加载中 ─── */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ─── 小程序码 ─── */
.qrcode-img {
  width: 100%;
  min-height: 400rpx;
  background: #fff;
  padding: 20rpx;
  box-sizing: border-box;
}

/* ─── 二维码类型标签 ─── */
.qr-type-label {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: -16rpx;
  margin-bottom: 16rpx;
}

/* ─── 邀请码显示 ─── */
.invitation-code-box {
  margin: 24rpx 0;
  padding: 24rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
  border: 2rpx dashed var(--primary);
  border-radius: var(--radius-md);
  text-align: center;
}
.code-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}
.code-value-box {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.code-value {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: 4rpx;
}
.code-copy-btn {
  font-size: 24rpx;
  color: var(--primary);
  background: rgba(180, 30, 50, 0.08);
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}
.code-type-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: var(--primary);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* ─── 文字按钮 ─── */
.btn-text {
  background: transparent;
  color: var(--primary);
  border: none;
  font-size: 26rpx;
}
