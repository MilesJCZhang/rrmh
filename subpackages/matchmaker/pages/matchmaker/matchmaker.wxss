/* ============================================================
   pages/matchmaker/matchmaker.wxss
   社交中心 · 三种状态：引导绑定 / 推荐官介绍 / 工作台
   ============================================================ */

/* ---- 未绑定推荐官：双入口（申请推荐官 + 绑定推荐官） ---- */
.bind-hero {
  padding: 96rpx 48rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.bind-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}
.bind-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  font-family: STKaiti, KaiTi, serif;
  letter-spacing: 3rpx;
}
.bind-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.7;
  max-width: 500rpx;
}

/* 双入口卡片：申请推荐官 + 绑定推荐官 */
.dual-entry {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.de-card {
  position: relative;
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-md);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}
.de-card--apply {
  border-left: 8rpx solid #C8102E;
}
.de-card--bind {
  border-left: 8rpx solid #F59E0B;
}
.de-card::before {
  content: '';
  position: absolute;
  right: -30rpx;
  bottom: -30rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  opacity: 0.08;
}
.de-card--apply::before {
  background: #C8102E;
}
.de-card--bind::before {
  background: #F59E0B;
}
.de-emoji {
  font-size: 44rpx;
}
.de-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}
.de-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}
.de-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}
.de-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: var(--red-light);
  color: #C8102E;
}
.de-card--bind .de-tag {
  background: #FEF3C7;
  color: #D97706;
}
.de-arrow {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: var(--text-muted);
}

/* 绑定说明列表 */
.tip-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.tip-item {
  display: flex;
  gap: 20rpx;
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}
.tip-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}
.tip-body {
  flex: 1;
}
.tip-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}
.tip-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

/* 联系客服卡片 */
.contact-card {
  background: #FFF7ED;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  border: 1rpx solid rgba(200,16,46,0.08);
}
.contact-label {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 12rpx;
}
.contact-wechat {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.contact-id {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.contact-copy {
  font-size: 24rpx;
  color: #FFFFFF;
  background: var(--red-primary);
  padding: 6rpx 24rpx;
  border-radius: 100rpx;
}

/* ---- 已绑定推荐官：我的推荐官介绍 ---- */
.my-mk-hero {
  padding: 64rpx 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.mk-avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
}
.mk-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
}
.mk-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.5);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 20rpx;
  border-radius: 100rpx;
  white-space: nowrap;
  backdrop-filter: blur(8rpx);
}
.mk-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 20rpx;
  font-family: STKaiti, KaiTi, serif;
  letter-spacing: 2rpx;
}
.mk-stats {
  display: flex;
  background: rgba(255,255,255,0.14);
  border-radius: var(--radius-lg);
  padding: 20rpx 48rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(4rpx);
}
.mks-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.mks-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
}
.mks-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}
.mks-divider {
  width: 1rpx;
  background: rgba(255,255,255,0.2);
  margin: 4rpx 32rpx;
}
.mk-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.7;
  max-width: 520rpx;
}

/* ---- 其他推荐官列表 ---- */
.other-mk-section {
  padding-bottom: 32rpx;
}
.mk-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 16rpx;
}
.mk-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-light);
}
.mkc-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 16rpx;
}
.mkc-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid var(--red-light);
  flex-shrink: 0;
}
.mkc-info {
  flex: 1;
}
.mkc-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}
.mkc-role {
  font-size: 22rpx;
  color: var(--red-primary);
  background: var(--red-pale);
  padding: 2rpx 14rpx;
  border-radius: 100rpx;
  display: inline-block;
}
.mkc-role-partner {
  background: #FEF3C7;
  color: #92400E;
}
.mkc-stats {
  flex-shrink: 0;
}
.mkc-num {
  font-size: 26rpx;
  color: var(--text-muted);
}
.mkc-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 16rpx;
}
.mkc-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}
.mkc-rating {
  font-size: 24rpx;
  color: #F59E0B;
}
.mkc-star {
  margin-right: 4rpx;
}
.mkc-action {
  font-size: 24rpx;
  color: var(--red-primary);
  font-weight: 600;
}

/* ============================================================
   以下为推荐官工作台样式（保持不变）
   ============================================================ */

/* ---- 申请引导页 ---- */
.apply-hero {
  padding: 96rpx 48rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
}
.apply-hero::before {
  content: '❃';
  position: absolute;
  right: -20rpx; top: -20rpx;
  font-size: 280rpx;
  color: rgba(255,255,255,0.05);
  pointer-events: none;
}
.apply-emoji {
  font-size: 88rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 8rpx 16rpx rgba(0,0,0,0.2));
}
.apply-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 14rpx;
  font-family: STKaiti, KaiTi, serif;
  letter-spacing: 3rpx;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}
.apply-desc {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.7;
  max-width: 480rpx;
}

/* ---- 收益说明卡片宫格 ---- */
.income-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.income-item {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: var(--shadow-md);
  border: 1rpx solid rgba(200,16,46,0.05);
}
.income-icon   { font-size: 52rpx; margin-bottom: 10rpx; }
.income-amount {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--red-primary);
  margin-bottom: 6rpx;
  font-family: STKaiti, KaiTi, serif;
}
.income-label  { font-size: 22rpx; color: var(--text-muted); line-height: 1.5; }

/* ---- 收益概览（大卡） ---- */
.income-overview {
  padding: 56rpx 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}
.income-overview::before {
  content: '\2743';
  position: absolute;
  right: -20rpx; top: -20rpx;
  font-size: 280rpx;
  color: rgba(255,255,255,0.05);
  pointer-events: none;
}

/* 头像 */
.ov-avatar-wrap {
  margin-bottom: 16rpx;
}
.ov-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
}

/* 名称 + 身份徽章 */
.ov-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  font-family: STKaiti, KaiTi, serif;
  letter-spacing: 2rpx;
}
.ov-role-badge {
  background: rgba(255,255,255,0.18);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 4rpx 24rpx;
  border-radius: 100rpx;
  margin-bottom: 32rpx;
  backdrop-filter: blur(8rpx);
}

/* 本月收益大字 */
.ov-income-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 28rpx;
}
.ov-income-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 8rpx;
}
.ov-income-amount {
  font-size: 72rpx;
  font-weight: 900;
  color: #FFFFFF;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

/* 概览名称（旧版兼容） */
.overview-name {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}
.overview-total {
  margin-bottom: 36rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.ot-label  {
  font-size: 26rpx;
  color: rgba(255,255,255,0.70);
}
.ot-amount {
  font-size: 72rpx;
  font-weight: 900;
  color: #FFFFFF;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

/* 旧版 overview-top 兼容 */
.overview-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
  width: 100%;
}
.overview-top .ov-avatar {
  width: 96rpx;
  height: 96rpx;
}
.overview-top .ov-info {
  display: flex;
  flex-direction: column;
}
.overview-top .ov-name {
  font-size: 34rpx;
  margin-bottom: 4rpx;
}
.overview-top .ov-role {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}
.overview-income {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 28rpx;
}
.overview-income .oi-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 8rpx;
}
.overview-income .oi-amount {
  font-size: 64rpx;
  font-weight: 900;
  color: #FFFFFF;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.overview-stats {
  display: flex;
  width: 100%;
  background: rgba(255,255,255,0.14);
  border-radius: var(--radius-lg);
  padding: 24rpx 0;
  backdrop-filter: blur(4rpx);
}
.os-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.os-num    { font-size: 38rpx; font-weight: 800; color: #FFFFFF; }
.os-num-highlight {
  color: #FFD700;
  text-shadow: 0 2rpx 8rpx rgba(255,215,0,0.3);
}
.os-label  { font-size: 22rpx; color: rgba(255,255,255,0.70); }
.os-divider { width: 1rpx; background: rgba(255,255,255,0.20); margin: 4rpx 0; }

/* ---- 联创推荐官：沙龙补贴条 ---- */
.salon-subsidy-bar {
  width: 100%;
  margin-top: 20rpx;
  background: rgba(255,215,0,0.15);
  border: 1rpx solid rgba(255,215,0,0.25);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ssb-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.ssb-icon {
  font-size: 40rpx;
}
.ssb-text {
  display: flex;
  flex-direction: column;
}
.ssb-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFD700;
}
.ssb-desc {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
}
.ssb-amount {
  font-size: 26rpx;
  font-weight: 800;
  color: #FFD700;
}

/* ---- 身份升级列表 ---- */
.upgrade-entries {
  width: 100%;
  margin-top: 20rpx;
  background: rgba(255,255,255,0.12);
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
}
.ue-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}
.ue-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.ue-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}
.ue-item:last-child {
  border-bottom: none;
}
.ue-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.ue-icon {
  font-size: 36rpx;
}
.ue-info {
  display: flex;
  flex-direction: column;
}
.ue-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.ue-desc {
  font-size: 20rpx;
  color: rgba(255,255,255,0.65);
  margin-top: 4rpx;
}
.ue-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.ue-fee {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFD700;
  background: rgba(255,215,0,0.2);
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  white-space: nowrap;
}
.ue-fee-free {
  color: #7DFFB3;
  background: rgba(125,255,179,0.15);
}
.ue-arrow {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

/* ---- 快捷操作宫格 ---- */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.qa-item {
  background: #FFFFFF;
  border-radius: var(--radius-md);
  padding: 28rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid rgba(200,16,46,0.05);
}
.qa-item:active { background: var(--red-pale); }
.qa-icon  { font-size: 48rpx; }
.qa-text  { font-size: 22rpx; color: var(--text-secondary); text-align: center; }

/* ---- 收益流水列表 ---- */
.earnings-list { display: flex; flex-direction: column; gap: 16rpx; }
.earning-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}
.ei-left     { display: flex; align-items: center; gap: 18rpx; }
.ei-type-icon { font-size: 44rpx; }
.ei-desc     { font-size: 26rpx; color: var(--text-primary); display: block; margin-bottom: 4rpx; }
.ei-time     { font-size: 22rpx; color: var(--text-hint); }
.ei-amount   {
  font-size: 34rpx;
  font-weight: 800;
  color: #16a34a;
}

/* ---- 会员列表 ---- */
.members-list { display: flex; flex-direction: column; gap: 16rpx; }
.member-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #FFFFFF;
  border-radius: var(--radius-md);
  padding: 18rpx 28rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}
.member-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
  border: 3rpx solid var(--red-light);
}
.member-info { flex: 1; }
.member-name   { font-size: 28rpx; font-weight: 600; display: block; margin-bottom: 4rpx; color: var(--text-primary); }
.member-status { font-size: 22rpx; color: var(--text-muted); }
.member-time   { font-size: 22rpx; color: var(--text-hint); }

/* ---- 通用辅助 ---- */
.link-text    { font-size: 26rpx; color: var(--red-primary); }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.empty-sub    { font-size: 22rpx; color: var(--text-hint); margin-top: 8rpx; text-align: center; }

/* ---- 联创推荐官按钮 ---- */
.partner-btn {
  border-color: #7C3AED !important;
  color: #7C3AED !important;
}
.partner-btn:active {
  background: #F5F3FF !important;
}

/* ============================================================
   业务统计看板样式（公益/联创推荐官工作台）
   ============================================================ */

/* 统计区域 */
.stats-section {
  padding-bottom: 32rpx;
}
.stats-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 统计卡片网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

/* 单个统计卡片 */
.stat-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-md);
  border: 1rpx solid rgba(200,16,46,0.05);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-height: 160rpx;
}
.stat-card:active {
  background: #FEF2F2;
}

/* 高亮卡片（沙龙补贴等） */
.stat-card-highlight {
  background: linear-gradient(135deg, #FEF9C3 0%, #FDE68A 100%);
  border-color: rgba(245,158,11,0.2);
}
.stat-card-highlight:active {
  background: #FEF3C7;
}

/* 卡片图标 */
.stat-icon {
  font-size: 40rpx;
  line-height: 1;
}

/* 卡片主体（数量+标签） */
.stat-body {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.1;
}
.stat-lbl {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 收益金额区域 */
.stat-income-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
  margin-top: auto;
}
.stat-income {
  font-size: 26rpx;
  font-weight: 700;
  color: #16a34a;
}
.stat-income-lbl {
  font-size: 18rpx;
  color: var(--text-hint);
}

/* 收益说明卡片 */
.notice-box {
  background: #FEF9C3;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  border: 1rpx solid rgba(245,158,11,0.2);
}
.notice-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #92400E;
  display: block;
  margin-bottom: 16rpx;
}
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.notice-item {
  font-size: 22rpx;
  color: #78350F;
  line-height: 1.6;
}
