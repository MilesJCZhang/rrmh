/* pages/verify/verify.wxss - 实名认证 */

.verify-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}
.vr-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}
.vr-success { background: linear-gradient(135deg, #4ADE80, #22C55E); }
.vr-pending { background: linear-gradient(135deg, #FBBF24, #F59E0B); }
.vr-rejected { background: linear-gradient(135deg, #F87171, #EF4444); }
.vr-icon { font-size: 56rpx; color: #FFFFFF; font-weight: 700; }
.vr-title { font-size: 36rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 16rpx; }
.vr-desc { font-size: 26rpx; color: var(--text-muted); text-align: center; line-height: 1.6; max-width: 500rpx; }
.vr-info { width: 100%; max-width: 500rpx; margin-top: 40rpx; background: #FFFFFF; border-radius: var(--radius-lg); padding: 32rpx; box-shadow: var(--shadow-sm); }
.vri-item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; }
.vri-item + .vri-item { border-top: 1rpx solid var(--border); }
.vri-label { font-size: 28rpx; color: var(--text-muted); }
.vri-value { font-size: 28rpx; color: var(--text-primary); font-weight: 600; }

.form-header { display: flex; flex-direction: column; align-items: center; padding: 48rpx 32rpx 32rpx; }
.fh-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.fh-title { font-size: 40rpx; font-weight: 800; color: var(--text-primary); margin-bottom: 12rpx; }
.fh-desc { font-size: 26rpx; color: var(--text-muted); text-align: center; line-height: 1.6; max-width: 500rpx; }

/* 敏感个人信息声明 */
.sensitive-notice { margin: 0 32rpx; padding: 32rpx; background: #FFFBF5; border-radius: 16rpx; border: 2rpx solid #FDE68A; }
.sn-title { font-size: 30rpx; font-weight: 700; color: #92400E; margin-bottom: 20rpx; }
.sn-intro { font-size: 26rpx; color: #78350F; line-height: 1.8; margin-bottom: 24rpx; }
.sn-card { background: #FFFFFF; border-radius: 12rpx; padding: 8rpx 0; margin-bottom: 24rpx; }
.sn-item { padding: 20rpx 24rpx; }
.sn-item + .sn-item { border-top: 1rpx solid #FEF3C7; }
.sn-label { display: block; font-size: 26rpx; font-weight: 700; color: #78350F; margin-bottom: 8rpx; }
.sn-text { display: block; font-size: 26rpx; color: #92400E; line-height: 1.6; }
.sn-warning { display: flex; align-items: flex-start; background: #FEF2F2; border-radius: 12rpx; padding: 20rpx 24rpx; }
.sn-warn-icon { flex-shrink: 0; width: 36rpx; height: 36rpx; border-radius: 50%; background: #EF4444; color: #FFFFFF; font-size: 24rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; margin-top: 2rpx; }
.sn-warn-text { font-size: 26rpx; color: #991B1B; line-height: 1.6; }

.form-group { display: flex; flex-direction: column; overflow: visible; }
.form-label { width: auto; flex-shrink: 0; font-size: 28rpx; font-weight: 600; color: var(--text-primary); line-height: 1.6; margin-bottom: 12rpx; overflow: visible; }
.form-input { width: 100%; flex: none; height: 96rpx; background: #F8F9FA; border-radius: var(--radius-md); padding: 0 28rpx; font-size: 30rpx; color: var(--text-primary); border: 2rpx solid transparent; box-sizing: border-box; }
.form-input:focus { border-color: var(--red-primary); background: #FFFFFF; }

.form-tips { background: #FFF7ED; border-radius: var(--radius-md); padding: 24rpx; }
.ft-item { display: block; font-size: 24rpx; color: #92400E; line-height: 1.8; }

.agreement { display: flex; align-items: flex-start; }
.agreement-label { display: flex; align-items: center; flex-wrap: wrap; }
.agreement-text { font-size: 24rpx; color: var(--text-muted); }
.agreement-link { font-size: 24rpx; color: var(--red-primary); }

/* 微信 button[disabled] 默认文字变灰，覆盖为白色 */
.btn-primary[disabled] { color: #FFFFFF; opacity: 0.7; }
